---
import BaseLayout from '@/layouts/BaseLayout.astro';
const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout title="404 - Halaman Tidak Ditemukan" description="Halaman tidak ditemukan">
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center px-4">
    <div class="text-6xl font-bold text-[var(--v)] mb-4 font-mono">404</div>
    <h1 class="text-2xl font-bold text-[var(--t1)] mb-4">Halaman Tidak Ditemukan</h1>
    <p class="text-[var(--t2)] mb-8 max-w-md">Halaman yang Anda cari mungkin telah dipindahkan atau tidak pernah ada.</p>
    <a href={baseUrl} class="inline-flex items-center gap-2 px-6 py-3 bg-[var(--v)] text-[var(--bg)] font-bold rounded-lg hover:opacity-90 transition-opacity">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
      Kembali ke Beranda
    </a>
  </div>
</BaseLayout>