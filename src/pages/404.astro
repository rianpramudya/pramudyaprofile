---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { dictionary } from "@/i18n/dictionary";
import type { Lang } from "@/i18n/dictionary";

const baseUrl = import.meta.env.BASE_URL;

// ── Ambil bahasa dari URL (SSR) ──
function getLangFromUrl(url: URL): Lang {
  const q = url.searchParams.get("lang");
  if (q === "en" || q === "id") return q;
  return "id";
}

const lang = getLangFromUrl(Astro.url);

function ts(key: string): string {
  const dict = dictionary[lang] as Record<string, string | string[]>;
  const val = dict[key];
  if (typeof val === "string") return val;
  return key;
}
---

<BaseLayout title={ts("404.title")} description={ts("404.desc")}>
  <meta slot="head" name="robots" content="noindex, nofollow" />

  <main
    class="relative min-h-[80vh] flex flex-col items-center justify-center px-6 overflow-hidden"
  >
    {/* ── Ambient Background ── */}
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div
        class="absolute top-[30%] left-[50%] -translate-x-1/2 w-[500px] h-[500px] bg-[var(--orb-v)] rounded-full blur-[150px] opacity-[0.08]"
      >
      </div>
      <div
        class="absolute inset-0 opacity-[0.02]"
        style="background-image: linear-gradient(var(--t1) 1px, transparent 1px), linear-gradient(90deg, var(--t1) 1px, transparent 1px); background-size: 48px 48px;"
      >
      </div>
    </div>

    <div class="relative z-10 flex flex-col items-center text-center max-w-lg">
      {/* ── Status Badge ── */}
      <div
        class="inline-flex items-center gap-3 border-l-2 border-[var(--v)] pl-3 mb-10"
      >
        <span
          class="font-mono text-[0.65rem] tracking-[0.2em] text-[var(--t3)] uppercase"
        >
          SYS_STATE // 404
        </span>
        <span
          class="flex items-center gap-1.5 font-mono text-[0.55rem] text-[var(--v)] bg-[var(--v)]/10 px-2 py-0.5 uppercase tracking-widest"
        >
          <span class="w-1.5 h-1.5 bg-[var(--v)] rounded-sm animate-pulse"
          ></span>
          NOT_FOUND
        </span>
      </div>

      {/* ── 404 Number ── */}
      <div
        class="font-['Syne','Inter','Helvetica_Neue',sans-serif] font-black text-[clamp(6rem,15vw,10rem)] leading-[0.85] tracking-tight mb-6 text-transparent [-webkit-text-stroke:2px_var(--v)] opacity-80"
      >
        404
      </div>

      {/* ── Title ── */}
      <h1
        class="font-['Syne',sans-serif] font-bold text-[clamp(1.5rem,4vw,2.2rem)] text-[var(--t1)] mb-4 tracking-tight"
        data-i18n="404.heading"
      >
        {ts("404.heading")}
      </h1>

      {/* ── Description ── */}
      <p
        class="text-[var(--t2)] text-sm md:text-base leading-relaxed font-light mb-10 max-w-md"
        data-i18n="404.desc"
      >
        {ts("404.desc")}
      </p>

      {/* ── Back Button ── */}
      <a
        href={`${baseUrl}?lang=${lang}`}
        class="relative group overflow-hidden flex items-center justify-center gap-3 bg-[var(--v)] text-[var(--bg)] font-bold font-mono text-xs tracking-[0.2em] uppercase px-10 py-5 transition-all duration-300 hover:shadow-[0_0_25px_var(--shadow-v)] [clip-path:polygon(0_0,100%_0,100%_calc(100%-12px),calc(100%-12px)_100%,0_100%)]"
        data-i18n="404.backBtn"
      >
        <span class="relative z-10">{ts("404.backBtn")}</span>
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="relative z-10 group-hover:-translate-x-1 transition-transform"
        >
          <path d="m12 19-7-7 7-7"></path>
          <path d="M19 12H5"></path>
        </svg>
        <div
          class="absolute inset-0 bg-white/20 translate-y-[100%] group-hover:translate-y-0 transition-transform duration-300 ease-in-out pointer-events-none"
        >
        </div>
      </a>
    </div>
  </main>
</BaseLayout>
