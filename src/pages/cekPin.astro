---
// src/pages/cekPin.astro
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Admin — CV PIN Checker"
  description="Halaman admin untuk mengecek PIN aktif CV"
>
  <meta slot="head" name="robots" content="noindex, nofollow" />

  <main
    class="min-h-screen bg-[#04040f] flex flex-col items-center justify-center p-4 pt-28 pb-16 relative overflow-hidden"
  >
    <!-- Background glow -->
    <div
      class="absolute inset-0 pointer-events-none flex items-center justify-center"
    >
      <div
        class="w-[600px] h-[600px] bg-emerald-500/5 rounded-full blur-[120px]"
      >
      </div>
    </div>

    <div class="relative z-10 w-full max-w-md flex flex-col gap-4">
      <!-- Card utama -->
      <div
        class="bg-[#0a0a0a] border border-white/8 rounded-3xl p-8 text-center shadow-[0_20px_60px_rgba(16,185,129,0.1)]"
      >
        <!-- Badge -->
        <div
          class="inline-flex items-center gap-2 bg-emerald-500/10 border border-emerald-500/20 rounded-full px-4 py-1.5 text-xs font-semibold text-emerald-400 uppercase tracking-widest mb-7"
        >
          <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse"
          ></span>
          Admin Only
        </div>

        <h1 class="text-2xl font-bold text-white mb-1.5 tracking-tight">
          CV PIN Aktif
        </h1>
        <p class="text-sm text-slate-500 mb-8">
          Kirimkan PIN ini ke pemohon yang sudah kamu verifikasi.
        </p>

        <!-- PIN Box -->
        <div
          class="relative bg-[#111] border border-emerald-500/25 rounded-2xl px-5 pb-6 pt-7 mb-6 overflow-hidden"
        >
          <!-- top shimmer line -->
          <div
            class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-emerald-500/50 to-transparent"
          >
          </div>

          <p
            class="text-[10px] font-semibold text-slate-500 uppercase tracking-[0.12em] mb-3"
          >
            PIN Saat Ini
          </p>
          <div
            id="pin-display"
            class="font-mono text-5xl font-black tracking-[0.18em] leading-none bg-gradient-to-br from-emerald-300 to-emerald-600 bg-clip-text text-transparent"
          >
            ······
          </div>

          <button
            id="copy-btn"
            class="mt-5 bg-emerald-500/10 hover:bg-emerald-500/20 border border-emerald-500/20 text-emerald-400 text-xs font-semibold px-5 py-2 rounded-lg transition-all duration-200 hover:-translate-y-0.5"
          >
            Salin PIN
          </button>
        </div>

        <!-- Timer -->
        <div class="flex flex-col items-center gap-2.5 mb-6">
          <p class="text-xs text-slate-500">PIN berganti dalam</p>
          <p
            id="countdown"
            class="font-mono text-lg font-bold text-slate-200 tracking-wider"
          >
            --:--:--
          </p>
          <div class="w-full h-1 bg-slate-800 rounded-full overflow-hidden">
            <div
              id="timer-bar"
              class="h-full bg-gradient-to-r from-emerald-700 to-emerald-400 rounded-full transition-[width] duration-1000 linear"
              style="width:100%"
            >
            </div>
          </div>
        </div>

        <!-- Info rows -->
        <div
          class="bg-white/[0.02] border border-white/5 rounded-xl px-4 py-3 text-left flex flex-col gap-3"
        >
          <div class="flex justify-between items-center text-xs">
            <span class="text-slate-500">Durasi valid</span>
            <span class="font-mono text-slate-400">3 jam / PIN</span>
          </div>
          <div class="h-px bg-white/[0.04]"></div>
          <div class="flex justify-between items-center text-xs">
            <span class="text-slate-500">Halaman akses user</span>
            <span class="font-mono text-slate-400">/AccessCV</span>
          </div>
          <div class="h-px bg-white/[0.04]"></div>
          <div class="flex justify-between items-center text-xs">
            <span class="text-slate-500">PIN sebelumnya</span>
            <span id="prev-pin" class="font-mono text-slate-400">······</span>
          </div>
        </div>
      </div>

      <!-- Tombol akses ke halaman CV Access -->
      <a
        href="/pramudyaprofile/AccessCV"
        class="group w-full flex items-center justify-between px-6 py-4 rounded-2xl bg-[#0a0a0a] border border-white/8 hover:border-emerald-500/30 transition-all duration-300 hover:shadow-[0_0_24px_rgba(16,185,129,0.08)]"
      >
        <div class="flex items-center gap-3">
          <div
            class="w-9 h-9 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center flex-shrink-0"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-emerald-400"
            >
              <rect width="18" height="11" x="3" y="11" rx="2" ry="2"></rect>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
          </div>
          <div class="text-left">
            <p class="text-sm font-semibold text-white">
              Buka Halaman CV Access
            </p>
            <p class="text-xs text-slate-500">
              /AccessCV — halaman yang dilihat user
            </p>
          </div>
        </div>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-slate-600 group-hover:text-emerald-400 group-hover:translate-x-1 transition-all duration-200"
        >
          <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </main>
</BaseLayout>

<script>
  // ============================================================
  // HARUS SAMA PERSIS dengan yang ada di AccessCV.astro
  // ============================================================
  const SECRET_KEY = "PRAMUDYA2026RIFKYCV"; // ← Ganti ini!
  const WINDOW_HOURS = 3;
  const PIN_LENGTH = 6;
  // ============================================================

  async function generatePIN(timeSlot = 0) {
    const now = Math.floor(Date.now() / 1000);
    const windowSeconds = WINDOW_HOURS * 3600;
    const currentSlot = Math.floor(now / windowSeconds) + timeSlot;
    const message = `${SECRET_KEY}:${currentSlot}`;

    const encoder = new TextEncoder();
    const data = encoder.encode(message);
    const hashBuffer = await crypto.subtle.digest("SHA-256", data);
    const hashArray = Array.from(new Uint8Array(hashBuffer));

    const num =
      ((hashArray[0] << 24) |
        (hashArray[1] << 16) |
        (hashArray[2] << 8) |
        hashArray[3]) >>>
      0;

    return String(num % Math.pow(10, PIN_LENGTH)).padStart(PIN_LENGTH, "0");
  }

  function getSecondsUntilExpiry() {
    const now = Math.floor(Date.now() / 1000);
    const ws = WINDOW_HOURS * 3600;
    return ws - (now % ws);
  }

  function formatTime(s: number) {
    const h = Math.floor(s / 3600);
    const m = Math.floor((s % 3600) / 60);
    const sec = s % 60;
    return `${String(h).padStart(2, "0")}:${String(m).padStart(2, "0")}:${String(sec).padStart(2, "0")}`;
  }

  let currentPINValue = "";

  async function refresh() {
    currentPINValue = await generatePIN(0);
    const prevPIN = await generatePIN(-1);
    (document.getElementById("pin-display") as HTMLElement).textContent =
      currentPINValue;
    (document.getElementById("prev-pin") as HTMLElement).textContent = prevPIN;
  }

  function tick() {
    const total = WINDOW_HOURS * 3600;
    const remain = getSecondsUntilExpiry();
    const pct = (remain / total) * 100;
    (document.getElementById("countdown") as HTMLElement).textContent =
      formatTime(remain);
    (document.getElementById("timer-bar") as HTMLElement).style.width =
      pct + "%";
    if (remain === total - 1) refresh();
  }

  document.getElementById("copy-btn")?.addEventListener("click", async () => {
    if (!currentPINValue) return;
    await navigator.clipboard.writeText(currentPINValue);
    const btn = document.getElementById("copy-btn") as HTMLButtonElement;
    btn.textContent = "✓ Tersalin!";
    setTimeout(() => {
      btn.textContent = "Salin PIN";
    }, 2000);
  });

  refresh();
  tick();
  setInterval(tick, 1000);
</script>
