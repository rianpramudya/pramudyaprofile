---
// src/pages/cekPin.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import { dictionary } from "@/i18n/dictionary";
import type { Lang } from "@/i18n/dictionary";

// ── SSR: ambil bahasa dari URL, sama persis seperti Hero.astro ──
function getLangFromUrl(url: URL): Lang {
  const q = url.searchParams.get("lang");
  if (q === "en" || q === "id") return q;
  return "id";
}

const lang = getLangFromUrl(Astro.url);

function ts(key: string): string {
  const dict = dictionary[lang] as Record<string, any>;
  const val = dict[key];
  if (typeof val === "string") return val;
  return key;
}

// FIX: link ke AccessCV wajib ikut bawa ?lang= biar bahasa tidak reset
const accessCvHref = `/pramudyaprofile/AccessCV?lang=${lang}`;
---

<BaseLayout title={ts("cekPin.title")} description={ts("cekPin.desc")}>
  <meta slot="head" name="robots" content="noindex, nofollow" />

  <main class="admin-page">
    <!-- Background glow -->
    <div class="admin-orb-wrap" aria-hidden="true">
      <div class="admin-orb"></div>
    </div>

    <div class="admin-inner">
      <!-- ── Card Utama ── -->
      <div class="admin-card">
        <!-- Badge -->
        <div class="admin-badge">
          <span class="admin-badge-dot"></span>
          <span data-i18n="cekPin.badge">{ts("cekPin.badge")}</span>
        </div>

        <h1 class="admin-title" data-i18n="cekPin.heading">
          {ts("cekPin.heading")}
        </h1>
        <p class="admin-subtitle" data-i18n="cekPin.subtitle">
          {ts("cekPin.subtitle")}
        </p>

        <!-- PIN Box -->
        <div class="pin-box">
          <div class="pin-shimmer" aria-hidden="true"></div>

          <p class="pin-box-label" data-i18n="cekPin.pinLabel">
            {ts("cekPin.pinLabel")}
          </p>
          <div id="pin-display" class="pin-value">······</div>

          <button
            id="copy-btn"
            class="pin-copy-btn"
            type="button"
            data-i18n="cekPin.copyBtn"
            data-label-copied={ts("cekPin.copiedBtn")}
          >
            {ts("cekPin.copyBtn")}
          </button>
        </div>

        <!-- Timer -->
        <div class="timer-wrap">
          <p class="timer-label" data-i18n="cekPin.timerLabel">
            {ts("cekPin.timerLabel")}
          </p>
          <p id="countdown" class="timer-countdown">--:--:--</p>
          <div class="timer-track">
            <div id="timer-bar" class="timer-bar" style="width:100%"></div>
          </div>
        </div>

        <!-- Info rows -->
        <div class="info-rows">
          <div class="info-row">
            <span class="info-key" data-i18n="cekPin.infoValidityLabel"
              >{ts("cekPin.infoValidityLabel")}</span
            >
            <span class="info-val" data-i18n="cekPin.infoValidity"
              >{ts("cekPin.infoValidity")}</span
            >
          </div>
          <div class="info-divider"></div>
          <div class="info-row">
            <span class="info-key" data-i18n="cekPin.infoAccessLabel"
              >{ts("cekPin.infoAccessLabel")}</span
            >
            <span class="info-val">/AccessCV</span>
          </div>
          <div class="info-divider"></div>
          <div class="info-row">
            <span class="info-key" data-i18n="cekPin.infoPrevLabel"
              >{ts("cekPin.infoPrevLabel")}</span
            >
            <span id="prev-pin" class="info-val">······</span>
          </div>
        </div>
      </div>

      <!-- ── Link ke halaman AccessCV ── -->
      <a href={accessCvHref} class="access-link">
        <div class="access-link-icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect width="18" height="11" x="3" y="11" rx="2" ry="2"></rect>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
          </svg>
        </div>
        <div class="access-link-text">
          <p class="access-link-title" data-i18n="cekPin.linkTitle">
            {ts("cekPin.linkTitle")}
          </p>
          <p class="access-link-sub" data-i18n="cekPin.linkSub">
            {ts("cekPin.linkSub")}
          </p>
        </div>
        <svg
          class="access-link-arrow"
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </main>
</BaseLayout>

<style>
  /* ══════════════════════════════════════════
     PAGE SHELL
  ══════════════════════════════════════════ */
  .admin-page {
    min-height: 100vh;
    background: var(--bg);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 7rem 1.25rem 3rem;
    position: relative;
    overflow: hidden;
  }

  .admin-orb-wrap {
    position: absolute;
    inset: 0;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .admin-orb {
    width: 600px;
    height: 600px;
    background: var(--orb-v);
    border-radius: 50%;
    filter: blur(100px);
  }

  .admin-inner {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 440px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* ══════════════════════════════════════════
     MAIN CARD
  ══════════════════════════════════════════ */
  .admin-card {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 2rem;
    text-align: center;
    box-shadow: var(--card-shadow);
  }

  .admin-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--vd);
    border: 1px solid var(--v-ring-rest);
    border-radius: 999px;
    padding: 0.3rem 1rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--v);
    margin-bottom: 1.75rem;
  }
  .admin-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--g);
    animation: pulse-g 2s infinite;
  }
  @keyframes pulse-g {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.5;
      transform: scale(0.85);
    }
  }

  .admin-title {
    font-family: "Syne", sans-serif;
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--t1);
    margin: 0 0 0.4rem;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }
  .admin-subtitle {
    font-size: 0.85rem;
    color: var(--t2);
    line-height: 1.6;
    font-weight: 300;
    margin: 0 0 2rem;
  }

  /* ══════════════════════════════════════════
     PIN BOX
  ══════════════════════════════════════════ */
  .pin-box {
    position: relative;
    background: var(--bg-3);
    border: 1px solid var(--border-2);
    border-radius: 14px;
    padding: 1.75rem 1.25rem 1.5rem;
    margin-bottom: 1.5rem;
    overflow: hidden;
  }
  .pin-shimmer {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--v), transparent);
    opacity: 0.6;
  }
  .pin-box-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--t3);
    margin: 0 0 0.75rem;
  }
  .pin-value {
    font-family: "JetBrains Mono", monospace;
    font-size: 3rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    line-height: 1;
    background: linear-gradient(135deg, var(--c) 0%, var(--v) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1.25rem;
  }
  .pin-copy-btn {
    background: var(--vd);
    border: 1px solid var(--v-ring-rest);
    color: var(--v);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.5rem 1.4rem;
    border-radius: 8px;
    cursor: pointer;
    transition:
      background 0.2s,
      border-color 0.2s,
      transform 0.2s;
  }
  .pin-copy-btn:hover {
    background: rgba(16, 185, 129, 0.2);
    border-color: var(--v);
    transform: translateY(-1px);
  }

  /* ══════════════════════════════════════════
     TIMER
  ══════════════════════════════════════════ */
  .timer-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1.5rem;
  }
  .timer-label {
    font-size: 0.78rem;
    color: var(--t3);
    margin: 0;
  }
  .timer-countdown {
    font-family: "JetBrains Mono", monospace;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--t1);
    letter-spacing: 0.12em;
    margin: 0;
  }
  .timer-track {
    width: 100%;
    height: 4px;
    background: var(--bg-3);
    border: 1px solid var(--border);
    border-radius: 999px;
    overflow: hidden;
  }
  .timer-bar {
    height: 100%;
    background: linear-gradient(to right, var(--border-2), var(--v));
    border-radius: 999px;
    transition: width 1s linear;
  }

  /* ══════════════════════════════════════════
     INFO ROWS
  ══════════════════════════════════════════ */
  .info-rows {
    background: var(--bg-3);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.75rem 1rem;
    text-align: left;
  }
  .info-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.35rem 0;
  }
  .info-key {
    font-size: 0.75rem;
    color: var(--t3);
  }
  .info-val {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.72rem;
    color: var(--t2);
    font-weight: 600;
  }
  .info-divider {
    height: 1px;
    background: var(--border);
    margin: 0.1rem 0;
  }

  /* ══════════════════════════════════════════
     ACCESS LINK
  ══════════════════════════════════════════ */
  .access-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-radius: 16px;
    background: var(--bg-2);
    border: 1px solid var(--border);
    text-decoration: none;
    transition:
      border-color 0.25s,
      box-shadow 0.25s;
  }
  .access-link:hover {
    border-color: var(--v-ring-rest);
    box-shadow: 0 0 20px var(--orb-v);
  }
  .access-link:hover .access-link-arrow {
    transform: translateX(3px);
    color: var(--v);
  }
  .access-link-icon {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 10px;
    background: var(--vd);
    border: 1px solid var(--v-ring-rest);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--v);
  }
  .access-link-text {
    flex: 1;
    text-align: left;
  }
  .access-link-title {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--t1);
    margin: 0 0 0.15rem;
  }
  .access-link-sub {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.62rem;
    color: var(--t3);
    margin: 0;
    letter-spacing: 0.04em;
  }
  .access-link-arrow {
    color: var(--t3);
    flex-shrink: 0;
    transition:
      transform 0.2s,
      color 0.2s;
  }
</style>

<script>
  // ============================================================
  // KONFIGURASI
  // ============================================================
  const SECRET_KEY = "PRAMUDYA2026RIFKYCV";
  const WINDOW_HOURS = 3;
  const PIN_LENGTH = 6;

  // ── Referensi elemen ──
  const pinDisplay = document.getElementById("pin-display");
  const prevPin = document.getElementById("prev-pin");
  const countdown = document.getElementById("countdown");
  const timerBar = document.getElementById("timer-bar");
  const copyBtn = document.getElementById("copy-btn");

  // ── FIX UTAMA: ambil teks i18n LIVE (ikut bahasa aktif saat ini) ──
  function liveText(key, fallback) {
    if (window.i18n && window.i18n.t) {
      const val = window.i18n.t(key);
      if (val && val !== key) return val;
    }
    return fallback;
  }

  // ── Fungsi generate PIN ──
  async function generatePIN(timeSlot) {
    timeSlot = timeSlot || 0;
    if (!window.crypto || !crypto.subtle) {
      throw new Error("Web Crypto API tidak tersedia.");
    }

    const now = Math.floor(Date.now() / 1000);
    const windowSeconds = WINDOW_HOURS * 3600;
    const currentSlot = Math.floor(now / windowSeconds) + timeSlot;
    const message = SECRET_KEY + ":" + currentSlot;
    const encoder = new TextEncoder();
    const data = encoder.encode(message);
    const hashBuffer = await crypto.subtle.digest("SHA-256", data);
    const hashArray = Array.from(new Uint8Array(hashBuffer));
    const num =
      ((hashArray[0] << 24) |
        (hashArray[1] << 16) |
        (hashArray[2] << 8) |
        hashArray[3]) >>>
      0;
    return String(num % Math.pow(10, PIN_LENGTH)).padStart(PIN_LENGTH, "0");
  }

  function getSecondsUntilExpiry() {
    const now = Math.floor(Date.now() / 1000);
    const ws = WINDOW_HOURS * 3600;
    return ws - (now % ws);
  }

  function formatTime(s) {
    const h = Math.floor(s / 3600);
    const m = Math.floor((s % 3600) / 60);
    const sec = s % 60;
    return (
      String(h).padStart(2, "0") +
      ":" +
      String(m).padStart(2, "0") +
      ":" +
      String(sec).padStart(2, "0")
    );
  }

  let currentPINValue = "";

  async function refresh() {
    try {
      currentPINValue = await generatePIN(0);
      const prevPIN = await generatePIN(-1);

      if (pinDisplay) pinDisplay.textContent = currentPINValue;
      if (prevPin) prevPin.textContent = prevPIN;
    } catch (err) {
      console.error("Gagal generate PIN:", err);
      if (pinDisplay) pinDisplay.textContent = "ERROR";
    }
  }

  function tick() {
    const total = WINDOW_HOURS * 3600;
    const remain = getSecondsUntilExpiry();
    const pct = (remain / total) * 100;

    if (countdown) countdown.textContent = formatTime(remain);
    if (timerBar) timerBar.style.width = pct + "%";

    if (remain === total - 1) refresh();
  }

  // ── Copy button (FIXED) ──
  if (copyBtn) {
    copyBtn.addEventListener("click", async function () {
      if (!currentPINValue) return;
      try {
        await navigator.clipboard.writeText(currentPINValue);
        const idleKey = copyBtn.getAttribute("data-i18n"); // "cekPin.copyBtn"

        // FIX: tampilkan "Copied!" versi LIVE, bukan data-label-copied yang statis
        copyBtn.textContent = liveText(
          "cekPin.copiedBtn",
          copyBtn.getAttribute("data-label-copied") || "✓ Copied!",
        );

        setTimeout(function () {
          copyBtn.textContent = liveText(idleKey, copyBtn.textContent);
        }, 2000);
      } catch (err) {
        console.error("Gagal menyalin:", err);
      }
    });
  }

  // ── Jalankan ──
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", function () {
      refresh();
      tick();
      setInterval(tick, 1000);
    });
  } else {
    refresh();
    tick();
    setInterval(tick, 1000);
  }
</script>