---
import { site } from '@/content/site';
import Button from '@/components/ui/Button.astro';
import Badge from '@/components/ui/Badge.astro';
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden bg-[#04040f]">

  <!--
    BACKGROUND: Constellation Field
    - Canvas fullscreen, pointer-events-none agar tidak block interaksi konten
    - Tiga layer bintang dengan kecepatan parallax berbeda
    - Nebula clouds, koneksi konstelasi, meteor shower acak
    - Mouse parallax: bintang bergerak mengikuti kursor
  -->
  <canvas
    id="hero-canvas"
    class="absolute inset-0 w-full h-full pointer-events-none"
    aria-hidden="true"
  ></canvas>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8 lg:gap-12 items-center">

      <!-- LEFT / TOP: Hero Content -->
      <div class="lg:col-span-3 text-center">

        <!-- Availability Badge -->
        <div class="inline-flex mb-8 opacity-0" id="hero-badge">
          <Badge variant="primary" size="md">
            <span class="relative flex h-2.5 w-2.5">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-primary-500"></span>
            </span>
            Tersedia untuk proyek baru
          </Badge>
        </div>

        <!-- Name -->
        <h1 class="text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight">
          <span class="block opacity-0 translate-y-8" id="hero-line1">Rian Pramudya</span>
          <span class="block opacity-0 translate-y-8" id="hero-line2">
            <span class="bg-gradient-to-r from-primary-400 via-accent-400 to-primary-400 bg-clip-text text-transparent animate-gradient bg-[length:200%_auto]">Amanda</span>
          </span>
        </h1>

        <!-- Role -->
        <p class="text-lg sm:text-xl md:text-2xl text-slate-400 mb-4 font-medium opacity-0" id="hero-role">
          Full Stack Web Developer & <span class="text-primary-400">AI Enthusiast</span>
        </p>

        <!-- Tagline -->
        <p class="text-slate-500 max-w-2xl mx-auto mb-10 text-sm sm:text-base leading-relaxed opacity-0" id="hero-desc">
          Mahasiswa Informatika Telkom University yang membangun solusi teknologi inovatif di bidang
          <span class="text-slate-300">Web Development</span>,
          <span class="text-slate-300">Machine Learning</span>, dan
          <span class="text-slate-300">Generative AI</span>.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 opacity-0" id="hero-cta">
          <Button href="#projects" size="lg">
            Lihat Proyek Saya
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </Button>
          <Button href="#contact" variant="outline" size="lg">
            Hubungi Saya
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </Button>
        </div>

        <!-- Lanyard Mobile -->
        <div class="flex justify-center mt-10 lg:hidden" id="hero-lanyard-mobile" style="opacity: 0;">
          <div
            id="lanyard-container-mobile"
            class="relative pointer-events-auto cursor-grab active:cursor-grabbing scale-[0.7] sm:scale-75"
          >
            <div class="w-48 mx-auto">
              <svg class="w-full" viewBox="0 0 192 140" fill="none" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <filter id="glow-m" x="-50%" y="-50%" width="200%" height="200%">
                    <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
                    <feMerge><feMergeNode in="coloredBlur"/><feMergeNode in="SourceGraphic"/></feMerge>
                  </filter>
                  <linearGradient id="rope-gradient-m" x1="0%" y1="0%" x2="0%" y2="100%">
                    <stop offset="0%" stop-color="#10b981" />
                    <stop offset="50%" stop-color="#14b8a6" />
                    <stop offset="100%" stop-color="#06b6d4" />
                  </linearGradient>
                </defs>
                <circle cx="16" cy="8" r="5.5" fill="#0f172a" stroke="#14b8a6" stroke-width="2.5" filter="url(#glow-m)" />
                <circle cx="176" cy="8" r="5.5" fill="#0f172a" stroke="#14b8a6" stroke-width="2.5" filter="url(#glow-m)" />
                <path d="M16 8 Q56 88 96 132" stroke="url(#rope-gradient-m)" stroke-width="4.5" stroke-linecap="round" fill="none" filter="url(#glow-m)" />
                <path d="M176 8 Q136 88 96 132" stroke="url(#rope-gradient-m)" stroke-width="4.5" stroke-linecap="round" fill="none" filter="url(#glow-m)" />
                <circle cx="96" cy="132" r="9" fill="#1e293b" stroke="#64748b" stroke-width="2" />
                <circle cx="96" cy="132" r="4" fill="#475569" />
              </svg>
              <div class="relative -mt-3">
                <div class="w-full rounded-2xl overflow-hidden bg-gradient-to-b from-slate-800 to-dark-800 border-2 border-emerald-500/30 shadow-[0_20px_60px_-15px_rgba(16,185,129,0.25)] backdrop-blur-sm relative">
                  <div class="h-3 bg-gradient-to-r from-emerald-500 via-teal-500 to-cyan-500"></div>
                  <div class="relative h-44 bg-gradient-to-br from-slate-800 to-slate-900 overflow-hidden px-4 pt-4">
                    <div class="absolute inset-0 flex items-center justify-center">
                      <div class="relative">
                        <div class="absolute inset-0 rounded-full bg-emerald-500/20 blur-xl scale-110"></div>
                        <img src={`${import.meta.env.BASE_URL}/rian.jpg`} alt="Rian Pramudya Amanda" class="relative w-28 h-28 rounded-full object-cover border-4 border-dark-800 shadow-2xl" />
                      </div>
                    </div>
                    <div class="absolute inset-0 bg-gradient-to-t from-dark-800/90 via-transparent to-transparent"></div>
                  </div>
                  <div class="p-4 text-center relative">
                    <p class="text-white font-bold text-base tracking-tight">Rian Pramudya</p>
                    <p class="text-emerald-400 text-sm font-medium mt-1">Full Stack Developer</p>
                    <div class="mt-3 flex justify-center gap-2 items-center px-3 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/20 w-fit mx-auto">
                      <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                      <span class="text-xs text-emerald-300 font-medium">Available for hire</span>
                    </div>
                  </div>
                  <div class="absolute -top-2 left-1/2 -translate-x-1/2 w-7 h-7 rounded-full bg-dark-900 border-2 border-slate-600 flex items-center justify-center z-20">
                    <div class="w-2.5 h-2.5 rounded-full bg-slate-500"></div>
                  </div>
                </div>
                <div class="absolute -bottom-6 left-1/2 -translate-x-1/2 w-36 h-6 bg-emerald-500/10 rounded-full blur-2xl"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-6 sm:gap-10 max-w-lg mx-auto mt-16 opacity-0" id="hero-stats">
          <div class="text-center group">
            <div class="text-2xl sm:text-3xl md:text-4xl font-bold text-white font-display group-hover:text-primary-400 transition-colors duration-300">5+</div>
            <div class="text-xs sm:text-sm text-slate-500 mt-1">Proyek Selesai</div>
          </div>
          <div class="text-center group">
            <div class="text-2xl sm:text-3xl md:text-4xl font-bold text-white font-display group-hover:text-primary-400 transition-colors duration-300">3+</div>
            <div class="text-xs sm:text-sm text-slate-500 mt-1">Tahun Pengalaman</div>
          </div>
          <div class="text-center group">
            <div class="text-2xl sm:text-3xl md:text-4xl font-bold text-white font-display group-hover:text-primary-400 transition-colors duration-300">25+</div>
            <div class="text-xs sm:text-sm text-slate-500 mt-1">Skill Teknologi</div>
          </div>
        </div>

      </div>

      <!-- RIGHT: Lanyard Desktop -->
      <div class="lg:col-span-1 hidden lg:flex items-center justify-center">
        <div id="lanyard-container" class="relative pointer-events-auto cursor-grab active:cursor-grabbing scale-75 xl:scale-90">
          <div class="w-56 mx-auto">
            <svg class="w-full" viewBox="0 0 224 160" fill="none" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
                  <feGaussianBlur stdDeviation="3.5" result="coloredBlur"/>
                  <feMerge><feMergeNode in="coloredBlur"/><feMergeNode in="SourceGraphic"/></feMerge>
                </filter>
                <linearGradient id="rope-gradient" x1="0%" y1="0%" x2="0%" y2="100%">
                  <stop offset="0%" stop-color="#10b981" />
                  <stop offset="50%" stop-color="#14b8a6" />
                  <stop offset="100%" stop-color="#06b6d4" />
                </linearGradient>
              </defs>
              <circle cx="20" cy="8" r="6" fill="#0f172a" stroke="#14b8a6" stroke-width="2.5" filter="url(#glow)" />
              <circle cx="204" cy="8" r="6" fill="#0f172a" stroke="#14b8a6" stroke-width="2.5" filter="url(#glow)" />
              <path d="M20 8 Q66 100 112 152" stroke="url(#rope-gradient)" stroke-width="5" stroke-linecap="round" fill="none" filter="url(#glow)" />
              <path d="M204 8 Q158 100 112 152" stroke="url(#rope-gradient)" stroke-width="5" stroke-linecap="round" fill="none" filter="url(#glow)" />
              <circle cx="112" cy="152" r="10" fill="#1e293b" stroke="#64748b" stroke-width="2" />
              <circle cx="112" cy="152" r="4.5" fill="#475569" />
            </svg>
            <div class="relative -mt-3">
              <div class="w-full rounded-2xl overflow-hidden bg-gradient-to-b from-slate-800 to-dark-800 border-2 border-emerald-500/30 shadow-[0_20px_60px_-15px_rgba(16,185,129,0.25)] backdrop-blur-sm relative">
                <div class="h-3 bg-gradient-to-r from-emerald-500 via-teal-500 to-cyan-500"></div>
                <div class="relative h-52 bg-gradient-to-br from-slate-800 to-slate-900 overflow-hidden px-4 pt-4">
                  <div class="absolute inset-0 flex items-center justify-center">
                    <div class="relative">
                      <div class="absolute inset-0 rounded-full bg-emerald-500/20 blur-xl scale-110"></div>
                      <img src={`${import.meta.env.BASE_URL}/rian.jpg`} alt="Rian Pramudya Amanda" class="relative w-32 h-32 sm:w-36 sm:h-36 rounded-full object-cover border-4 border-dark-800 shadow-2xl" />
                    </div>
                  </div>
                  <div class="absolute inset-0 bg-gradient-to-t from-dark-800/90 via-transparent to-transparent"></div>
                </div>
                <div class="p-4 text-center relative">
                  <p class="text-white font-bold text-lg tracking-tight">Rian Pramudya</p>
                  <p class="text-emerald-400 text-sm font-medium mt-1">Full Stack Developer</p>
                  <div class="mt-3 flex justify-center gap-2 items-center px-3 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/20 w-fit mx-auto">
                    <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse"></span>
                    <span class="text-xs text-emerald-300 font-medium">Available for hire</span>
                  </div>
                </div>
                <div class="absolute -top-2 left-1/2 -translate-x-1/2 w-8 h-8 rounded-full bg-dark-900 border-2 border-slate-600 flex items-center justify-center z-20">
                  <div class="w-3 h-3 rounded-full bg-slate-500"></div>
                </div>
              </div>
              <div class="absolute -bottom-6 left-1/2 -translate-x-1/2 w-44 h-6 bg-emerald-500/10 rounded-full blur-2xl"></div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @keyframes lanyard-drop {
    0%   { transform: translateY(-60px) scale(0.9); opacity: 0; }
    60%  { transform: translateY(5px) scale(1.02); opacity: 1; }
    80%  { transform: translateY(-3px) scale(0.98); }
    100% { transform: translateY(0%) scale(1); }
  }
  @keyframes lanyard-swing {
    0%, 100% { transform: rotate(-1.5deg); }
    50%       { transform: rotate(1.5deg); }
  }
  @keyframes lanyard-swing-hover {
    0%, 100% { transform: rotate(-5deg); }
    25%      { transform: rotate(5deg); }
    50%      { transform: rotate(-3deg); }
    75%      { transform: rotate(3deg); }
  }

  #lanyard-container {
    animation: lanyard-drop 1.5s cubic-bezier(0.34,1.56,0.64,1) forwards,
               lanyard-swing 5s ease-in-out infinite 1.5s;
    transform-origin: top center;
  }
  #lanyard-container.is-swinging {
    animation: lanyard-drop 1.5s cubic-bezier(0.34,1.56,0.64,1) forwards,
               lanyard-swing-hover 2s ease-in-out infinite;
  }
  #lanyard-container.is-clicked {
    animation: lanyard-drop 1.5s cubic-bezier(0.34,1.56,0.64,1) forwards,
               lanyard-swing-hover 3s ease-in-out infinite;
  }

  #lanyard-container-mobile { transform-origin: top center; }
  #lanyard-container-mobile.is-idle     { animation: lanyard-swing 5s ease-in-out infinite; }
  #lanyard-container-mobile.is-swinging { animation: lanyard-swing-hover 2s ease-in-out infinite; }
  #lanyard-container-mobile.is-clicked  { animation: lanyard-swing-hover 3s ease-in-out infinite; }
</style>

<script>
  /* ═══════════════════════════════════════════════
     CONSTELLATION FIELD BACKGROUND
     3 layer bintang + nebula + koneksi + meteor
  ═══════════════════════════════════════════════ */
  (function () {
    const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
    if (!canvas) return;

    const ctx = canvas.getContext('2d')!;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);

    let W = 0, H = 0;
    let mouseX = -9999, mouseY = -9999;
    let animId: number;

    interface Star {
      x: number; y: number;
      vx: number; vy: number;
      r: number; baseAlpha: number;
      layer: number;
      twinkle: number; twinkleSpeed: number;
    }
    interface Meteor {
      x: number; y: number;
      vx: number; vy: number;
      life: number; len: number;
    }

    let stars: Star[] = [];
    let meteors: Meteor[] = [];

    function resize() {
      const rect = canvas.parentElement!.getBoundingClientRect();
      W = rect.width;
      H = rect.height;
      canvas.width  = W * dpr;
      canvas.height = H * dpr;
      canvas.style.width  = W + 'px';
      canvas.style.height = H + 'px';
      ctx.scale(dpr, dpr);
      buildStars();
    }

    function buildStars() {
      stars = [];
      const config = [
        { count: 120, speedMult: 0.06, rBase: 0.7,  alpha: 0.3  },
        { count: 70,  speedMult: 0.14, rBase: 1.1,  alpha: 0.55 },
        { count: 35,  speedMult: 0.28, rBase: 1.7,  alpha: 0.85 },
      ];
      config.forEach((c, layer) => {
        for (let i = 0; i < c.count; i++) {
          const angle = Math.random() * Math.PI * 2;
          const speed = c.speedMult * (0.5 + Math.random());
          stars.push({
            x: Math.random() * W,
            y: Math.random() * H,
            vx: Math.cos(angle) * speed,
            vy: Math.sin(angle) * speed,
            r: c.rBase * (0.6 + Math.random() * 0.8),
            baseAlpha: c.alpha,
            layer,
            twinkle: Math.random() * Math.PI * 2,
            twinkleSpeed: 0.015 + Math.random() * 0.035,
          });
        }
      });
    }

    function spawnMeteor() {
      if (meteors.length >= 4) return;
      meteors.push({
        x: Math.random() * W * 0.7,
        y: Math.random() * H * 0.35,
        vx: 3.5 + Math.random() * 3,
        vy: 1.8 + Math.random() * 2,
        life: 1,
        len: 55 + Math.random() * 70,
      });
    }

    const meteorInterval = setInterval(spawnMeteor, 2400);

    // Nebula blob configs — warna disesuaikan tema emerald/cyan/indigo
    const nebulaConfigs = [
      { xFrac: 0.18, yFrac: 0.28, r: 220, color: '16,185,129'  },
      { xFrac: 0.78, yFrac: 0.60, r: 180, color: '6,182,212'   },
      { xFrac: 0.50, yFrac: 0.75, r: 160, color: '99,102,241'  },
      { xFrac: 0.85, yFrac: 0.20, r: 130, color: '167,139,250' },
    ];

    function drawFrame() {
      ctx.clearRect(0, 0, W, H);

      // ── Nebula clouds ──────────────────────────────────────────
      nebulaConfigs.forEach(n => {
        const nx = n.xFrac * W;
        const ny = n.yFrac * H;
        const grad = ctx.createRadialGradient(nx, ny, 0, nx, ny, n.r);
        grad.addColorStop(0, `rgba(${n.color},0.10)`);
        grad.addColorStop(1, `rgba(${n.color},0)`);
        ctx.fillStyle = grad;
        ctx.beginPath();
        ctx.arc(nx, ny, n.r, 0, Math.PI * 2);
        ctx.fill();
      });

      // Mouse nebula — ikut kursor
      if (mouseX > 0) {
        const mg = ctx.createRadialGradient(mouseX, mouseY, 0, mouseX, mouseY, 110);
        mg.addColorStop(0, 'rgba(129,140,248,0.10)');
        mg.addColorStop(1, 'rgba(129,140,248,0)');
        ctx.fillStyle = mg;
        ctx.beginPath();
        ctx.arc(mouseX, mouseY, 110, 0, Math.PI * 2);
        ctx.fill();
      }

      // ── Stars ──────────────────────────────────────────────────
      stars.forEach(s => {
        s.twinkle += s.twinkleSpeed;

        // Parallax mouse: layer lebih tinggi → lebih responsif
        const parallaxStrength = (s.layer + 1) * 0.00012;
        s.x += s.vx + (mouseX > 0 ? (mouseX - W / 2) * parallaxStrength : 0);
        s.y += s.vy + (mouseY > 0 ? (mouseY - H / 2) * parallaxStrength : 0);

        // Wrap around edges
        if (s.x < -5) s.x = W + 5;
        if (s.x > W + 5) s.x = -5;
        if (s.y < -5) s.y = H + 5;
        if (s.y > H + 5) s.y = -5;

        const twinkle = 0.65 + Math.sin(s.twinkle) * 0.35;
        const alpha   = s.baseAlpha * twinkle;
        const radius  = s.r * (0.9 + Math.sin(s.twinkle * 0.7) * 0.1);

        ctx.beginPath();
        ctx.arc(s.x, s.y, radius, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(200,220,255,${alpha})`;
        ctx.fill();

        // Halo untuk bintang layer 2 (paling dekat)
        if (s.layer === 2 && s.baseAlpha > 0.8 && Math.random() < 0.004) {
          ctx.beginPath();
          ctx.arc(s.x, s.y, radius * 3.5, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(180,210,255,0.05)';
          ctx.fill();
        }
      });

      // ── Constellation lines (layer 1 only) ────────────────────
      const l1 = stars.filter(s => s.layer === 1);
      for (let i = 0; i < l1.length; i++) {
        for (let j = i + 1; j < l1.length; j++) {
          const d = Math.hypot(l1[i].x - l1[j].x, l1[i].y - l1[j].y);
          if (d < 80) {
            ctx.strokeStyle = `rgba(99,102,241,${(1 - d / 80) * 0.15})`;
            ctx.lineWidth = 0.5;
            ctx.beginPath();
            ctx.moveTo(l1[i].x, l1[i].y);
            ctx.lineTo(l1[j].x, l1[j].y);
            ctx.stroke();
          }
        }
      }

      // ── Meteors ────────────────────────────────────────────────
      for (let i = meteors.length - 1; i >= 0; i--) {
        const m = meteors[i];
        m.x    += m.vx;
        m.y    += m.vy;
        m.life -= 0.018;
        if (m.life <= 0 || m.x > W + 50 || m.y > H + 50) {
          meteors.splice(i, 1);
          continue;
        }
        const tailLen = m.len * m.life;
        const tx = m.x - (m.vx / Math.hypot(m.vx, m.vy)) * tailLen;
        const ty = m.y - (m.vy / Math.hypot(m.vx, m.vy)) * tailLen;
        const tail = ctx.createLinearGradient(tx, ty, m.x, m.y);
        tail.addColorStop(0, 'rgba(200,220,255,0)');
        tail.addColorStop(0.6, `rgba(200,220,255,${m.life * 0.4})`);
        tail.addColorStop(1,   `rgba(220,240,255,${m.life * 0.9})`);
        ctx.strokeStyle = tail;
        ctx.lineWidth   = 1.5 * m.life;
        ctx.lineCap     = 'round';
        ctx.beginPath();
        ctx.moveTo(tx, ty);
        ctx.lineTo(m.x, m.y);
        ctx.stroke();
      }

      animId = requestAnimationFrame(drawFrame);
    }

    // Mouse tracking pada section hero
    const section = canvas.closest('section')!;
    section.addEventListener('mousemove', (e: MouseEvent) => {
      const r = section.getBoundingClientRect();
      mouseX = e.clientX - r.left;
      mouseY = e.clientY - r.top;
    });
    section.addEventListener('mouseleave', () => {
      mouseX = -9999;
      mouseY = -9999;
    });

    window.addEventListener('resize', () => {
      cancelAnimationFrame(animId);
      ctx.setTransform(1, 0, 0, 1, 0, 0);
      resize();
      drawFrame();
    });

    resize();
    drawFrame();
  })();
</script>

<script>
  /* Hero entrance animations */
  const animateElements = [
    { id: 'hero-badge',  delay: 200  },
    { id: 'hero-line1',  delay: 400  },
    { id: 'hero-line2',  delay: 600  },
    { id: 'hero-role',   delay: 800  },
    { id: 'hero-desc',   delay: 1000 },
    { id: 'hero-cta',    delay: 1200 },
    { id: 'hero-stats',  delay: 1600 },
  ];
  animateElements.forEach(({ id, delay }) => {
    setTimeout(() => {
      const el = document.getElementById(id);
      if (el) {
        el.classList.remove('opacity-0', 'translate-y-8');
        el.classList.add('animate-fade-in-up');
      }
    }, delay);
  });

  /* Lanyard mobile fade-in */
  setTimeout(() => {
    const wrapper = document.getElementById('hero-lanyard-mobile');
    if (wrapper) {
      wrapper.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
      wrapper.style.transform  = 'translateY(-8px)';
      requestAnimationFrame(() => requestAnimationFrame(() => {
        wrapper.style.opacity   = '1';
        wrapper.style.transform = 'translateY(0)';
      }));
    }
    setTimeout(() => {
      const c = document.getElementById('lanyard-container-mobile');
      if (c) c.classList.add('is-idle');
    }, 700);
  }, 1400);
</script>

<script>
  /* Lanyard swing interaction */
  (function () {
    function attachSwing(id: string) {
      const el = document.getElementById(id);
      if (!el) return;
      let t: ReturnType<typeof setTimeout>;
      const isMobile = id === 'lanyard-container-mobile';

      el.addEventListener('mouseenter', () => {
        if (isMobile) el.classList.remove('is-idle');
        el.classList.add('is-swinging');
      });
      el.addEventListener('mouseleave', () => {
        clearTimeout(t);
        t = setTimeout(() => {
          el.classList.remove('is-swinging');
          if (isMobile) el.classList.add('is-idle');
        }, 2000);
      });
      el.addEventListener('click', e => {
        e.stopPropagation();
        el.classList.remove('is-swinging', 'is-idle');
        void el.offsetWidth;
        el.classList.add('is-clicked');
        clearTimeout(t);
        t = setTimeout(() => {
          el.classList.remove('is-clicked');
          if (isMobile) el.classList.add('is-idle');
        }, 3000);
      });
    }
    attachSwing('lanyard-container');
    attachSwing('lanyard-container-mobile');
  })();
</script>