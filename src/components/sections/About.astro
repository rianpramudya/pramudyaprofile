---
import { dictionary } from "@/i18n/dictionary";
import type { Lang } from "@/i18n/dictionary";

function getLangFromUrl(url: URL): Lang {
  const q = url.searchParams.get("lang");
  if (q === "en" || q === "id") return q;
  return "id";
}

const lang = getLangFromUrl(Astro.url);

function ts(key: string): string {
  const dict = dictionary[lang] as Record<string, any>;
  const val = dict[key];
  if (typeof val === "string") return val;
  return key;
}

const experiences = [
  {
    type: "work",
    typeKey: "timeline.work",
    titleKey: "timeline.job1.title",
    companyKey: "timeline.job1.company",
    periodKey: "timeline.job1.period",
    descKeys: [
      "timeline.job1.desc1",
      "timeline.job1.desc2",
      "timeline.job1.desc3",
    ],
  },
  {
    type: "organization",
    typeKey: "timeline.org",
    titleKey: "timeline.org1.title",
    companyKey: "timeline.org1.company",
    periodKey: "timeline.org1.period",
    descKeys: [
      "timeline.org1.desc1",
      "timeline.org1.desc2",
      "timeline.org1.desc3",
    ],
  },
  {
    type: "education",
    typeKey: "timeline.edu",
    titleKey: "timeline.edu1.title",
    companyKey: "timeline.edu1.company",
    periodKey: "timeline.edu1.period",
    descKeys: [
      "timeline.edu1.desc1",
      "timeline.edu1.desc2",
      "timeline.edu1.desc3",
    ],
  },
];

const badgeMap: Record<string, string> = {
  work: "bw",
  organization: "bo",
  education: "be",
};
---

<section id="about" class="about-section">
  {/* ── AMBIENT BACKGROUND ── */}
  <div class="orb1"></div>
  <div class="orb2"></div>
  <div class="grid-bg"></div>

  <div class="wrap">
    <div class="section-header">
      <div class="eyebrow" data-i18n="about.eyebrow">{ts("about.eyebrow")}</div>
      <h2 class="sec-h rv" data-i18n-html="about.title">
        <span class="sec-h-line1">{ts("about.title").split(' ').slice(0, -1).join(' ')}</span>
        <span class="sec-h-line2">{ts("about.title").split(' ').slice(-1)}</span>
      </h2>
    </div>

    <div class="bio-full rv">
      <p data-i18n-html="about.p1">{ts("about.p1")}</p>
      <p data-i18n-html="about.p2">{ts("about.p2")}</p>
      <p data-i18n-html="about.p3">{ts("about.p3")}</p>
    </div>

    <div class="timeline-full">
      {
        experiences.map((exp, i) => (
          <div
            class="exp-card rv"
            style={`transition-delay: ${200 + i * 120}ms`}
          >
            <div class="exp-header">
              <div class="exp-meta">
                <span
                  class:list={["badge", badgeMap[exp.type]]}
                  data-i18n={exp.typeKey}
                >
                  {ts(exp.typeKey)}
                </span>
                <span class="exp-period" data-i18n={exp.periodKey}>
                  {ts(exp.periodKey)}
                </span>
              </div>
              <h3 class="exp-title" data-i18n={exp.titleKey}>
                {ts(exp.titleKey)}
              </h3>
              <p class="exp-company" data-i18n={exp.companyKey}>
                {ts(exp.companyKey)}
              </p>
            </div>
            <ul class="exp-desc">
              {exp.descKeys.map((key) => (
                <li data-i18n={key}>{ts(key)}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .about-section {
    background: var(--bg);
    padding: 7rem 2.5rem;
    position: relative;
    overflow: hidden;
  }

  /* ── AMBIENT BACKGROUND ── */
  .orb1 {
    position: absolute;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, var(--orb-v) 0%, transparent 65%);
    top: -10%;
    right: -10%;
    pointer-events: none;
    opacity: 0.08;
  }

  .orb2 {
    position: absolute;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, var(--orb-c) 0%, transparent 65%);
    bottom: 0;
    left: -10%;
    pointer-events: none;
    opacity: 0.05;
  }

  .grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, #000 30%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, #000 30%, transparent 100%);
    pointer-events: none;
    opacity: 0.5;
  }

  .wrap {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .section-header {
    margin-bottom: 4.5rem;
    text-align: left;
  }

  /* ── Eyebrow: border-left vertikal (konsisten dengan Skills & Contact) ── */
  .eyebrow {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--v);
    margin-bottom: 1.2rem;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    border-left: 2px solid var(--v);
    padding-left: 0.75rem;
  }

  /* ── Section Title: brutalism hover, sama dengan Projects ── */
  .sec-h {
    font-family: "Syne", "Inter", "Helvetica Neue", sans-serif;
    font-weight: 900;
    font-size: clamp(2.6rem, 6vw, 5rem);
    line-height: 0.85;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--t1);
    margin: 0;
    cursor: default;
    transition: color 0.5s ease;
  }

  .sec-h:hover {
    color: var(--v);
  }

  .sec-h-line1 {
    display: block;
    color: var(--t1);
    transition: color 0.5s ease;
  }

  .sec-h-line2 {
    display: block;
    color: transparent;
    -webkit-text-stroke: 1.5px var(--t1);
    opacity: 0.7;
    transition:
      -webkit-text-stroke-color 0.5s ease,
      opacity 0.5s ease,
      transform 0.5s ease;
  }

  .sec-h:hover .sec-h-line1 {
    color: var(--v);
  }

  .sec-h:hover .sec-h-line2 {
    -webkit-text-stroke-color: var(--v);
    opacity: 1;
    transform: translateX(8px);
  }

  .bio-full {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
    margin-bottom: 5rem;
    padding: 0 1rem;
  }

  .bio-full p {
    color: var(--t2);
    line-height: 1.85;
    font-size: 0.9rem;
    font-weight: 300;
    margin: 0;
  }

  .bio-full p :global(strong) {
    color: var(--t1);
    font-weight: 500;
  }

  .timeline-full {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .exp-card {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 2rem;
    position: relative;
    overflow: hidden;
    transition:
      border-color 0.3s,
      transform 0.3s,
      box-shadow 0.3s;
  }

  .exp-card:hover {
    border-color: var(--v);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -20px rgba(0, 0, 0, 0.4);
  }

  .exp-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--v), var(--c));
    opacity: 0;
    transition: opacity 0.3s;
  }

  .exp-card:hover::before {
    opacity: 1;
  }

  .exp-header {
    margin-bottom: 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
  }

  .exp-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .badge {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border-radius: 2px;
    font-weight: 500;
    line-height: 1;
  }

  .bw {
    background: var(--vd);
    color: var(--v);
  }
  .bo {
    background: var(--cd);
    color: var(--c);
  }
  .be {
    background: var(--od);
    color: var(--o);
  }

  .exp-period {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.65rem;
    color: var(--t3);
    letter-spacing: 0.04em;
  }

  .exp-title {
    font-family: "Syne", "Inter", "Helvetica Neue", sans-serif;
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--t1);
    letter-spacing: -0.01em;
    margin: 0 0 0.3rem 0;
    line-height: 1.25;
    transition: color 0.3s ease;
  }

  .exp-card:hover .exp-title {
    color: var(--v);
  }

  .exp-company {
    font-size: 0.85rem;
    color: var(--t2);
    margin: 0;
  }

  .exp-desc {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .exp-desc li {
    position: relative;
    padding-left: 1.2rem;
    font-size: 0.82rem;
    line-height: 1.7;
    color: var(--t3);
  }

  .exp-desc li::before {
    content: "›";
    position: absolute;
    left: 0;
    color: var(--v);
    font-weight: 700;
    font-size: 1rem;
    line-height: 1.4;
  }

  .rv {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.7s cubic-bezier(0.4, 0, 0.2, 1),
      transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .rv.in {
    opacity: 1;
    transform: none;
  }

  @media (max-width: 1024px) {
    .bio-full {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      padding: 0;
    }

    .timeline-full {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }

  @media (max-width: 768px) {
    .about-section {
      padding: 5rem 1.2rem;
    }

    .section-header {
      margin-bottom: 2rem;
    }

    .bio-full {
      margin-bottom: 3rem;
    }

    .exp-card {
      padding: 1.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .rv {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .sec-h-line2 {
      transition: none;
    }
  }
</style>

<script>
  const rvObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("in");
          rvObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
  );

  document.querySelectorAll(".rv").forEach((el) => {
    rvObserver.observe(el);
  });
</script>