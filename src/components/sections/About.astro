---
import SectionTitle from '@/components/ui/SectionTitle.astro';
import Card from '@/components/ui/Card.astro';
import { experiences } from '@/content/skills';

const typeColors = {
  work: 'from-primary-500/20 to-primary-600/10 border-primary-500/30',
  organization: 'from-accent-500/20 to-accent-600/10 border-accent-500/30',
  education: 'from-purple-500/20 to-purple-600/10 border-purple-500/30',
};

const typeLabels = {
  work: 'Pekerjaan',
  organization: 'Organisasi',
  education: 'Pendidikan',
};
---

<section id="about" class="relative py-20 md:py-32 bg-dark-900 overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-primary-500/3 to-transparent pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-1/3 h-1/2 bg-gradient-to-r from-accent-500/3 to-transparent pointer-events-none"></div>
  
  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    
    <!-- HEADER: Flex row (desktop), column (mobile) -->
    <div class="flex flex-col items-center gap-8 lg:gap-12 mb-16 text-center">
      
      <div class="max-w-2xl mx-auto">
        <SectionTitle
          label="Tentang Saya"
          title="Mengubah Ide Menjadi Solusi Digital"
          subtitle="Saya adalah mahasiswa Informatika Telkom University dengan passion mendalam dalam pengembangan teknologi. Berfokus pada Full-stack Web Development, Machine Learning, dan pemanfaatan Generative AI untuk solusi yang inovatif."
        />
        
        <!-- Professional Summary -->
        <div class="mt-8" data-aos="fade-up" data-aos-delay="200">
          <Card class="p-6 md:p-8" glow={true}>
            <div class="flex flex-col sm:flex-row items-center sm:items-start gap-4 text-center sm:text-left">
              <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-primary-500 to-accent-500 flex items-center justify-center flex-shrink-0 shadow-lg shadow-primary-500/20">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-white mb-2">Profesional Summary</h3>
                <p class="text-slate-400 leading-relaxed text-sm md:text-base">
                  Saya Rian Pramudya Amanda, mahasiswa Informatika Telkom University yang berfokus pada pengembangan 
                  <span class="text-primary-400 font-medium">Machine Learning</span>, 
                  <span class="text-primary-400 font-medium">Full-stack Web Development</span>, dan 
                  pemanfaatan ekosistem <span class="text-primary-400 font-medium">Generative AI</span>. 
                  Berkomitmen untuk terus belajar dan membangun solusi teknologi yang inovatif, efisien, serta berdampak nyata.
                </p>
              </div>
            </div>
          </Card>
        </div>
      </div>
      
    </div>

    <!-- Experience Timeline -->
    <div class="mb-16 md:mb-20">
      <h3 class="text-2xl md:text-3xl font-bold text-white text-center mb-12 font-display" data-aos="fade-up">
        Pengalaman & <span class="text-primary-400">Pendidikan</span>
      </h3>
      
      <div class="relative max-w-4xl mx-auto">
        <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-primary-500/50 via-slate-700 to-transparent md:-translate-x-1/2"></div>
        
        {experiences.map((exp, i) => (
          <!-- FIX #1: Ganti fade-right/fade-left → fade-up agar tidak terpotong di mobile -->
          <div class="relative flex items-start gap-6 mb-12 last:mb-0 md:items-center" data-aos="fade-up" data-aos-delay={i * 150}>
            <div class="absolute left-4 md:left-1/2 w-3 h-3 rounded-full bg-primary-500 border-4 border-dark-900 md:-translate-x-1/2 z-10 shadow-lg shadow-primary-500/30"></div>
            
            <div class:list={[
              'ml-12 md:ml-0 md:w-1/2',
              i % 2 === 0 ? 'md:pr-12 md:text-right' : 'md:pl-12 md:ml-auto'
            ]}>
              <Card class="p-6 hover:border-primary-500/30 transition-all duration-500">
                <span class:list={[
                  'inline-block px-3 py-1 rounded-full text-xs font-semibold mb-3 border',
                  'bg-gradient-to-r',
                  typeColors[exp.type]
                ]}>
                  {typeLabels[exp.type]}
                </span>
                <h4 class="text-lg font-bold text-white mb-1">{exp.title}</h4>
                <p class="text-primary-400 font-medium text-sm mb-1">{exp.company}</p>
                <p class="text-slate-500 text-xs mb-3">{exp.period}</p>
                <ul class="space-y-2">
                  {exp.description.map((desc) => (
                    <li class="text-slate-400 text-sm flex items-start gap-2">
                      <svg class="w-4 h-4 text-primary-500 mt-0.5 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                      <span>{desc}</span>
                    </li>
                  ))}
                </ul>
              </Card>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- FIX #2: Scroll indicator dihapus — sudah tidak konsisten dan redundant -->

  </div>
</section>