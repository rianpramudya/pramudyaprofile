---
import { skills, skillCategories } from '@/content/skills';

const iconMap: Record<string, string> = {
  'server': '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" x2="6.01" y1="6" y2="6"/><line x1="6" x2="6.01" y1="18" y2="18"/></svg>',
  'layout': '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>',
  'brain': '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"/><path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"/><path d="M3.477 10.896a4 4 0 0 1 .585-.396"/><path d="M19.938 10.5a4 4 0 0 1 .585.396"/><path d="M6 18a4 4 0 0 1-1.967-.516"/><path d="M19.967 17.484A4 4 0 0 1 18 18"/></svg>',
  'wrench': '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>',
  'palette': '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.01 17.461 2 12 2z"/></svg>',
};

const MAX_VISIBLE = 8;
---

<section id="skills" class="relative py-20 md:py-32 bg-dark-900 overflow-hidden">
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-slate-800 to-transparent"></div>
  <div class="absolute top-1/4 right-0 w-96 h-96 bg-cyan-600/10 rounded-full blur-[120px]"></div>
  
  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h3 class="text-2xl md:text-3xl font-bold text-white text-center mb-12 font-display" data-aos="fade-up">
      Skills & <span class="text-primary-400">Competencies</span>
    </h3>

    <!-- Category Tabs -->
    <div class="flex flex-wrap justify-center gap-2 mb-10" data-aos="fade-up" data-aos-delay="100">
      {skillCategories.map((cat) => (
        <button 
          class="skill-tab px-4 py-2 rounded-xl text-sm font-medium transition-all duration-300 border border-slate-700/50 text-slate-400 hover:text-white hover:border-primary-500/30 hover:bg-primary-500/5"
          data-category={cat.id}
        >
          <span class="flex items-center gap-2">
            <span set:html={iconMap[cat.icon] || ''} />
            {cat.label}
          </span>
        </button>
      ))}
      <button 
        class="skill-tab px-4 py-2 rounded-xl text-sm font-medium transition-all duration-300 border border-primary-500/50 text-primary-400 bg-primary-500/10"
        data-category="all"
      >
        Semua
      </button>
    </div>

    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 md:gap-5 max-w-6xl mx-auto"
      id="skills-grid"
    >
      {skills.map((skill, i) => (
        <div 
          class="skill-item group relative rounded-xl border border-slate-700/50 bg-dark-800/40 p-5 transition-all duration-500 hover:-translate-y-1 hover:border-primary-500/30 hover:bg-dark-800/80 hover:shadow-lg hover:shadow-primary-500/10"
          data-category={skill.category}
          data-index={i}
          style="display: none; opacity: 0;"
        >
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg bg-primary-500/10 flex items-center justify-center transition-all duration-300 group-hover:bg-dark-700">
                <i class={skill.icon} style="font-size: 20px;"></i>
              </div>
              <span class="text-slate-300 text-sm font-medium group-hover:text-white transition-colors duration-300">{skill.name}</span>
            </div>
            <span class="text-xs font-bold text-primary-400 bg-primary-500/10 px-2 py-1 rounded-md border border-primary-500/20">
              {skill.level}%
            </span>
          </div>
          
          <div class="h-2 bg-slate-700/50 rounded-full overflow-hidden">
            <div 
              class="skill-progress h-full bg-gradient-to-r from-primary-500 to-accent-500 rounded-full transition-all duration-1000 ease-out group-hover:from-primary-400 group-hover:to-accent-400"
              style={`width: 0%; --target-width: ${skill.level}%;`}
            ></div>
          </div>
          
          <div class="mt-2 flex items-center justify-between">
            <span class="text-[10px] text-slate-500 uppercase tracking-wider">{skill.category}</span>
            <span class:list={[
              'text-[10px] font-semibold px-1.5 py-0.5 rounded',
              skill.level >= 90 ? 'text-emerald-400 bg-emerald-500/10' :
              skill.level >= 80 ? 'text-cyan-400 bg-cyan-500/10' :
              skill.level >= 70 ? 'text-amber-400 bg-amber-500/10' :
              'text-slate-400 bg-slate-500/10'
            ]}>
              {skill.level >= 90 ? 'Expert' : skill.level >= 80 ? 'Advanced' : skill.level >= 70 ? 'Proficient' : 'Intermediate'}
            </span>
          </div>
        </div>
      ))}
    </div>

    <!-- Show More / Show Less Button -->
    <div class="text-center mt-10" id="show-more-container" style="display: none;">
      <button 
        id="show-more-btn"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-primary-500/30 text-primary-400 bg-primary-500/5 hover:bg-primary-500/10 hover:border-primary-500/50 transition-all duration-300 font-medium text-sm"
      >
        <span id="show-more-text">Lihat Skill Lainnya</span>
        <svg id="show-more-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
      </button>
    </div>
  </div>
</section>

<script>
  (function () {
    const MAX_VISIBLE = 8;
    let isExpanded = false;
    let currentCategory = 'all';
    let progressAnimated = false;

    const skillTabs = document.querySelectorAll('.skill-tab');
    const skillItems = document.querySelectorAll<HTMLElement>('.skill-item');
    const showMoreBtn = document.getElementById('show-more-btn');
    const showMoreText = document.getElementById('show-more-text');
    const showMoreIcon = document.getElementById('show-more-icon');
    const showMoreContainer = document.getElementById('show-more-container') as HTMLElement | null;

    function applyFilter() {
      let visibleCount = 0;
      let totalInCategory = 0;

      skillItems.forEach((item) => {
        const itemCategory = item.getAttribute('data-category');
        const matchesCategory =
          currentCategory === 'all' || itemCategory === currentCategory;

        if (matchesCategory) {
          totalInCategory++;
          const shouldShow = isExpanded || visibleCount < MAX_VISIBLE;

          if (shouldShow) {
            item.style.display = 'block';
            item.classList.add('aos-animate');
            requestAnimationFrame(() => {
              item.style.opacity = '1';
              item.style.transform = 'translateY(0)';
            });
            visibleCount++;
          } else {
            // Sembunyikan item dengan transisi
            item.style.opacity = '0';
            item.style.transform = 'translateY(10px)';
            // Delay display:none agar CSS transition selesai lebih dulu
            setTimeout(() => {
              if (item.style.opacity === '0') item.style.display = 'none';
            }, 300);
          }
        } else {
          // Kategori tidak cocok: langsung sembunyikan
          item.style.opacity = '0';
          item.style.transform = 'translateY(10px)';
          setTimeout(() => {
            if (item.style.opacity === '0') item.style.display = 'none';
          }, 300);
        }
      });

      updateShowMoreButton(totalInCategory);
    }

    function updateShowMoreButton(totalInCategory: number) {
      if (!showMoreContainer || !showMoreText || !showMoreIcon) return;

      // Berapa yang sekarang ditampilkan
      const shownCount = isExpanded
        ? totalInCategory
        : Math.min(totalInCategory, MAX_VISIBLE);
      // Berapa yang tersembunyi
      const hiddenCount = totalInCategory - shownCount;

      if (!isExpanded && hiddenCount > 0) {
        // Ada item tersembunyi → tampilkan tombol dengan jumlah yang akurat
        showMoreContainer.style.display = 'block';
        showMoreText.textContent = `Lihat ${hiddenCount} Skill Lainnya`;
        showMoreIcon.innerHTML = '<path d="m6 9 6 6 6-6"/>';
      } else if (isExpanded && totalInCategory > MAX_VISIBLE) {
        // Sedang expanded dan ada lebih dari MAX_VISIBLE → tombol sembunyikan
        showMoreContainer.style.display = 'block';
        showMoreText.textContent = 'Sembunyikan Skill';
        showMoreIcon.innerHTML = '<path d="m18 15-6-6-6 6"/>';
      } else {
        // Semua item dalam kategori ini ≤ MAX_VISIBLE → tombol tidak diperlukan
        showMoreContainer.style.display = 'none';
      }
    }

    skillTabs.forEach((tab) => {
      tab.addEventListener('click', function (this: HTMLElement, e) {
        e.preventDefault();
        e.stopPropagation();

        currentCategory = this.getAttribute('data-category') ?? 'all';
        isExpanded = false; // Reset expanded setiap ganti kategori

        // Update active state tab
        skillTabs.forEach((t) => {
          t.classList.remove('border-primary-500/50', 'text-primary-400', 'bg-primary-500/10');
          t.classList.add('border-slate-700/50', 'text-slate-400');
        });
        this.classList.remove('border-slate-700/50', 'text-slate-400');
        this.classList.add('border-primary-500/50', 'text-primary-400', 'bg-primary-500/10');

        applyFilter();
      });
    });

    if (showMoreBtn) {
      showMoreBtn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();

        isExpanded = !isExpanded;
        applyFilter();

        // Scroll kembali ke atas section saat menyembunyikan
        if (!isExpanded) {
          const skillsSection = document.getElementById('skills');
          if (skillsSection) {
            skillsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }
      });
    }

    const skillsGrid = document.getElementById('skills-grid');
    if (skillsGrid) {
      const progressObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && !progressAnimated) {
              progressAnimated = true;
              const bars = entry.target.querySelectorAll<HTMLElement>('.skill-progress');
              bars.forEach((bar, i) => {
                const targetWidth = bar.style.getPropertyValue('--target-width');
                if (targetWidth) {
                  setTimeout(() => {
                    bar.style.width = targetWidth;
                  }, i * 50);
                }
              });
              progressObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 } // Turunkan threshold agar trigger lebih cepat
      );
      progressObserver.observe(skillsGrid);
    }

    function init() {
      // Set active state pada tab "Semua"
      skillTabs.forEach((t) => {
        t.classList.remove('border-primary-500/50', 'text-primary-400', 'bg-primary-500/10');
        t.classList.add('border-slate-700/50', 'text-slate-400');
      });
      const allTab = document.querySelector<HTMLElement>('[data-category="all"]');
      if (allTab) {
        allTab.classList.remove('border-slate-700/50', 'text-slate-400');
        allTab.classList.add('border-primary-500/50', 'text-primary-400', 'bg-primary-500/10');
      }

      applyFilter();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>