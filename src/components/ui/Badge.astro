---
interface Props {
  variant?: 'primary' | 'accent' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { variant = 'primary', size = 'md', class: className = '' } = Astro.props;

const variants = {
  primary: 'bg-primary-500/10 text-primary-400 border-primary-500/20',
  accent: 'bg-accent-500/10 text-accent-400 border-accent-500/20',
  outline: 'bg-transparent text-slate-300 border-slate-600 hover:border-primary-500/50',
  ghost: 'bg-transparent text-slate-400 border-transparent',
};

const sizes = {
  sm: 'text-xs px-2 py-0.5',
  md: 'text-sm px-3 py-1',
  lg: 'text-base px-4 py-1.5',
};
---

<span class:list={[
  'inline-flex items-center gap-1.5 rounded-full border font-medium transition-all duration-300',
  variants[variant],
  sizes[size],
  className,
]}>
  <slot />
</span>
