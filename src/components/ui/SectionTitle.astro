---
interface Props {
  /** Small uppercase eyebrow label above the title */
  label?: string;

  /** Main heading text. If two words or more, the last word gets the hollow/stroke treatment */
  title: string;

  /** Optional supporting paragraph below the title */
  subtitle?: string;

  /** Text alignment */
  align?: 'left' | 'center';

  /**
   * split: true  → last word of `title` renders as a hollow/stroke accent
   *               (matches the brutalist heading style used in Hero + Projects)
   * split: false → plain solid heading
   */
  split?: boolean;

  /** AOS animation delay in ms */
  delay?: number;

  class?: string;
}

const {
  label,
  title,
  subtitle,
  align   = 'center',
  split   = true,
  delay   = 0,
  class: className = '',
} = Astro.props;

// Split heading: everything except the last word is solid,
// the last word gets the stroke/ghost treatment.
const words = title.trim().split(/\s+/).filter(Boolean);
const lastWord  = words.length > 1 ? words[words.length - 1] : '';
const firstPart = words.length > 1 ? words.slice(0, -1).join(' ') : title;
---

<div
  class:list={[
    'section-title-wrap',
    align === 'center' && 'align-center',
    align === 'left'   && 'align-left',
    className,
  ]}
  data-aos="fade-up"
  data-aos-delay={delay}
>
  {label && (
    <span class="st-eyebrow">
      <span class="st-eyebrow-line" aria-hidden="true"></span>
      {label}
      {align === 'center' && <span class="st-eyebrow-line" aria-hidden="true"></span>}
    </span>
  )}

  <h2 class="st-heading">
    {split && lastWord ? (
      <>
        <span class="st-solid">{firstPart}</span>
        {' '}
        <span class="st-stroke">{lastWord}</span>
      </>
    ) : (
      <span class="st-solid">{title}</span>
    )}
  </h2>

  {subtitle && (
    <p class="st-sub">{subtitle}</p>
  )}
</div>

<style>
  /* ══════════════════════════════════════════
     WRAPPER
  ══════════════════════════════════════════ */
  .section-title-wrap {
    max-width: 860px;
    margin-bottom: 4rem;
  }

  .align-center {
    margin-left:  auto;
    margin-right: auto;
    text-align:   center;
  }

  .align-left {
    text-align: left;
  }

  /* ══════════════════════════════════════════
     EYEBROW LABEL
  ══════════════════════════════════════════ */
  .st-eyebrow {
    display:        inline-flex;
    align-items:    center;
    gap:            0.65rem;
    font-family:    'JetBrains Mono', monospace;
    font-size:      0.65rem;
    font-weight:    700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color:          var(--v);
    margin-bottom:  1.1rem;
  }

  .st-eyebrow-line {
    display:    block;
    width:      28px;
    height:     1px;
    background: currentColor;
    flex-shrink: 0;
  }

  /* ══════════════════════════════════════════
     HEADING — brutalist two-line style
  ══════════════════════════════════════════ */
  .st-heading {
    font-family:     'Syne', sans-serif;
    font-weight:     900;
    font-size:       clamp(2.4rem, 5.5vw, 4.5rem);
    line-height:     0.9;
    letter-spacing:  -0.03em;
    text-transform:  uppercase;
    margin:          0 0 1.4rem 0;
  }

  /* Solid line — primary text colour (fully legible in both modes) */
  .st-solid {
    display: block;
    color:   var(--t1);
    transition: color 0.4s ease;
  }

  /* Stroke / ghost line — transparent fill with border */
  .st-stroke {
    display:             block;
    color:               transparent;
    -webkit-text-stroke: 1.5px var(--border-2);
    opacity:             0.75;
    transition:
      -webkit-text-stroke-color 0.4s ease,
      opacity                   0.4s ease;
  }

  /* Hover: both lines shift to accent */
  .st-heading:hover .st-solid {
    color: var(--v);
  }
  .st-heading:hover .st-stroke {
    -webkit-text-stroke-color: var(--v);
    opacity: 1;
  }

  /* ── Light mode: thicker stroke so ghost word is visible on bright bg ── */
  [data-theme="light"] .st-stroke {
    -webkit-text-stroke: 2px var(--border-2);
    opacity: 0.85;
  }
  [data-theme="light"] .st-heading:hover .st-stroke {
    -webkit-text-stroke-color: var(--v);
    opacity: 1;
  }

  /* ══════════════════════════════════════════
     SUBTITLE
  ══════════════════════════════════════════ */
  .st-sub {
    font-size:   0.95rem;
    line-height: 1.85;
    color:       var(--t2);   /* readable in both themes via CSS var */
    font-weight: 300;
    max-width:   580px;
    margin:      0;
  }

  /* Center mode: subtitle auto-centers */
  .align-center .st-sub {
    margin-left:  auto;
    margin-right: auto;
  }

  /* ══════════════════════════════════════════
     REDUCED MOTION
  ══════════════════════════════════════════ */
  @media (prefers-reduced-motion: reduce) {
    .st-solid,
    .st-stroke {
      transition: none;
    }
  }
</style>