---
interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  class?: string;
}

const { label, title, subtitle, align = 'center', class: className = '' } = Astro.props;

const alignClasses = {
  left: 'text-left',
  center: 'text-center',
};
---

<div class:list={['max-w-3xl mx-auto mb-16', alignClasses[align], className]} data-aos="fade-up">
  {label && (
    <span class="inline-flex items-center gap-2 text-primary-400 font-semibold text-sm uppercase tracking-wider mb-4">
      <span class="w-8 h-px bg-primary-500"></span>
      {label}
      <span class="w-8 h-px bg-primary-500"></span>
    </span>
  )}
  <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-4 font-display leading-tight">
    {title}
  </h2>
  {subtitle && (
    <p class="text-slate-400 text-base md:text-lg leading-relaxed max-w-2xl" class:list={align === 'center' && 'mx-auto'}>
      {subtitle}
    </p>
  )}
</div>
