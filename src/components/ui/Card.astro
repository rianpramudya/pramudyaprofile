---
interface Props {
  /**
   * visual  → standard elevated card (bg-2, border, shadow)
   * flat    → flush with page, lighter border only
   * ghost   → no background, border only (good for skill/tag grids)
   * glass   → subtle backdrop blur (for cards over images/orbs)
   */
  variant?: 'visual' | 'flat' | 'ghost' | 'glass';

  /** Enable lift + border-glow on hover */
  hover?: boolean;

  /**
   * glow: true → adds a faint emerald inner glow on hover.
   * Keep false if cards are dense/small to avoid visual noise.
   */
  glow?: boolean;

  /**
   * notch: true → clip-path bottom-right corner,
   * keeps language consistent with hero CTA / projects card style.
   */
  notch?: boolean;

  class?: string;
}

const {
  variant = 'visual',
  hover   = true,
  glow    = false,
  notch   = false,
  class: className = '',
} = Astro.props;
---

<div
  class:list={[
    'card-base',
    `card-${variant}`,
    hover  && 'card-hover',
    glow   && 'card-glow',
    notch  && 'card-notch',
    className,
  ]}
>
  <slot />
</div>

<style>
  /* ══════════════════════════════════════════
     BASE — shared by all variants
  ══════════════════════════════════════════ */
  .card-base {
    position:    relative;
    overflow:    hidden;
    border:      1px solid var(--card-border);
    border-radius: 12px;
    background:  var(--card-bg);
    box-shadow:  var(--card-shadow);
    transition:
      border-color 0.25s ease,
      box-shadow   0.25s ease,
      transform    0.25s ease;
  }

  /* ══════════════════════════════════════════
     VARIANTS
  ══════════════════════════════════════════ */

  /* visual: default — most opaque, strongest shadow */
  .card-visual {
    background: var(--bg-2);
    border-color: var(--border);
  }

  /* flat: same bg as page, lighter border — good for nested cards */
  .card-flat {
    background:  var(--bg-3);
    border-color: var(--border);
    box-shadow:  none;
  }

  /* ghost: transparent fill, border only */
  .card-ghost {
    background:  transparent;
    border-color: var(--border);
    box-shadow:  none;
  }

  /* glass: semi-transparent + blur — use over rich backgrounds */
  .card-glass {
    background:         rgba(255, 255, 255, 0.03);
    backdrop-filter:    blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-color:       var(--border);
  }
  [data-theme="light"] .card-glass {
    background: rgba(255, 255, 255, 0.55);
  }

  /* ══════════════════════════════════════════
     HOVER behaviour
  ══════════════════════════════════════════ */
  .card-hover {
    cursor: default;
  }
  .card-hover:hover {
    transform:    translateY(-3px);
    border-color: var(--card-hover-border);
    box-shadow:
      var(--card-shadow),
      0 0 0 1px var(--v-ring-rest);
  }

  /* ── Light mode hover: stronger lift shadow ── */
  [data-theme="light"] .card-hover:hover {
    box-shadow:
      0 2px 4px rgba(11, 45, 34, 0.08),
      0 8px 24px rgba(11, 45, 34, 0.12),
      0 0 0 1px var(--v);
  }

  /* ══════════════════════════════════════════
     GLOW modifier — faint emerald inner ring on hover
  ══════════════════════════════════════════ */
  .card-glow::before {
    content:    '';
    position:   absolute;
    inset:      0;
    background: radial-gradient(ellipse 60% 50% at 50% 0%, var(--vd) 0%, transparent 70%);
    opacity:    0;
    transition: opacity 0.4s ease;
    pointer-events: none;
    z-index:    0;
  }
  .card-glow:hover::before {
    opacity: 1;
  }

  /* Ensure slotted content sits above the glow layer */
  .card-glow > :global(*) {
    position: relative;
    z-index:  1;
  }

  /* ══════════════════════════════════════════
     NOTCH — clip-path bottom-right corner
     matches hero CTA / project case-frame style
  ══════════════════════════════════════════ */
  .card-notch {
    border-radius: 0;
    clip-path: polygon(
      0 0,
      100% 0,
      100% calc(100% - 20px),
      calc(100% - 20px) 100%,
      0 100%
    );
  }

  /* ══════════════════════════════════════════
     LIGHT MODE — ensure cards are clearly 
     distinguishable from the tinted page canvas
  ══════════════════════════════════════════ */
  [data-theme="light"] .card-visual {
    background:   #ffffff;
    border-color: var(--border);
    box-shadow:
      0 1px 2px rgba(11, 45, 34, 0.05),
      0 4px 16px rgba(11, 45, 34, 0.07),
      0 0 0 1px rgba(126, 201, 168, 0.40),
      inset 0 1px 0 rgba(255, 255, 255, 0.95);
  }

  [data-theme="light"] .card-flat {
    background:   var(--bg-3);       /* #f4faf7 — slightly off-white */
    border-color: var(--border);
    box-shadow:
      0 1px 3px rgba(11, 45, 34, 0.05),
      0 0 0 1px rgba(178, 221, 200, 0.50);
  }

  [data-theme="light"] .card-ghost {
    border-color: var(--border-2);
  }

  /* ══════════════════════════════════════════
     REDUCED MOTION
  ══════════════════════════════════════════ */
  @media (prefers-reduced-motion: reduce) {
    .card-base,
    .card-glow::before {
      transition: none;
    }
    .card-hover:hover {
      transform: none;
    }
  }
</style>