---
import { navigation } from "@/content/site";
import RequestCVModal from "@/components/ui/RequestCVModal.jsx";

const getNavIcon = (name: string) => {
  const n = name.toLowerCase();
  if (n.includes("beranda") || n.includes("home")) {
    return '<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>';
  }
  if (n.includes("tentang") || n.includes("about")) {
    return '<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>';
  }
  if (n.includes("skill") || n.includes("keahlian")) {
    return '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>';
  }
  if (n.includes("proyek") || n.includes("project")) {
    return '<path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>';
  }
  if (n.includes("kontak") || n.includes("contact")) {
    return '<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>';
  }
  return '<circle cx="12" cy="12" r="10"/><path d="m12 16 4-4-4-4"/><path d="M8 12h8"/>';
};
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 py-3 transition-all duration-500"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div
      id="nav-bar"
      class="flex h-14 items-center justify-between gap-3 rounded-2xl bg-dark-900/60 border border-white/10 px-3 sm:px-5 backdrop-blur-xl transition-all duration-300 relative z-50"
    >
      <a href="#hero" class="flex items-center gap-3 group flex-shrink-0">
        <div
          class="relative w-9 h-9 flex-shrink-0 flex items-center justify-center"
        >
          <svg
            viewBox="0 0 100 100"
            xmlns="http://www.w3.org/2000/svg"
            class="relative w-9 h-9 transform transition-transform duration-500 group-hover:scale-105"
          >
            <defs>
              <linearGradient id="pr-g6x" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#3b82f6"></stop>
                <stop offset="100%" stop-color="#2dd4bf"></stop>
              </linearGradient>
            </defs>
            <path
              d="M 50 3 L 97 50 L 50 97 L 3 50 Z"
              fill="none"
              stroke="url(#pr-g6x)"
              stroke-width="2"
              opacity="0.4"></path>
            <path
              d="M 50 16 L 84 50 L 50 84 L 16 50 Z"
              fill="none"
              stroke="url(#pr-g6x)"
              stroke-width="1.5"
              opacity="0.55"></path>
            <path
              d="M 33 32 L 33 68 M 33 32 L 55 32 Q 69 32 69 43 Q 69 54 55 54 L 33 54 M 47 54 L 67 72"
              fill="none"
              stroke="url(#pr-g6x)"
              stroke-width="7"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </div>
        <span
          class="text-white font-bold text-lg hidden sm:block font-display tracking-tight"
        >
          Pramudya<span class="text-primary-400 font-black">.site</span>
        </span>
      </a>

      <nav class="hidden md:flex items-center flex-1 justify-center">
        <div class="relative flex items-center gap-0.5">
          <div
            id="nav-indicator"
            class="absolute h-8 rounded-xl bg-primary-500/15 border border-primary-500/30 transition-all duration-300 pointer-events-none opacity-0"
          >
          </div>
          {
            navigation.map((item) => (
              <a
                href={item.href}
                class="nav-link relative z-10 px-4 py-1.5 text-sm font-medium text-slate-400 hover:text-white rounded-xl transition-colors duration-200 whitespace-nowrap"
                data-section={item.href}
              >
                {item.name}
              </a>
            ))
          }
        </div>
      </nav>

      <div class="hidden md:flex items-center gap-3 flex-shrink-0">
        <div class="flex items-center gap-2 text-xs text-slate-400 mr-2">
          <span class="relative flex h-2 w-2">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"
            ></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"
            ></span>
          </span>
          <span class="hidden lg:inline">Available</span>
        </div>

        <button
          type="button"
          class="cv-trigger-btn relative group inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-emerald-600 to-emerald-500 px-5 py-2 text-sm font-semibold text-white overflow-hidden transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-emerald-500/30"
        >
          <span
            class="absolute inset-0 -translate-x-full group-hover:translate-x-full transition-transform duration-700 bg-gradient-to-r from-transparent via-white/15 to-transparent skew-x-12"
          ></span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="relative"
          >
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline
              points="7 10 12 15 17 10"></polyline><line
              x1="12"
              x2="12"
              y1="15"
              y2="3"></line>
          </svg>
          <span class="relative">Lihat CV</span>
        </button>
      </div>

      <button
        id="dropdown-toggle-btn"
        class="md:hidden relative z-50 w-9 h-9 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-slate-300 hover:text-white transition-all duration-300"
      >
        <svg
          id="menu-icon-open"
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="4" x2="20" y1="6" y2="6"></line><line
            x1="4"
            x2="20"
            y1="12"
            y2="12"></line><line x1="4" x2="20" y1="18" y2="18"></line>
        </svg>
        <svg
          id="menu-icon-close"
          class="hidden"
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M18 6 6 18"></path><path d="m6 6 12 12"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<div id="dropdown-overlay" class="fixed inset-0 z-40 hidden"></div>

<div
  id="mobile-dropdown"
  class="fixed top-20 right-4 w-64 z-50 bg-[#1c1c1e]/95 backdrop-blur-2xl border border-white/10 rounded-2xl shadow-[0_16px_40px_rgba(0,0,0,0.5)] opacity-0 scale-95 pointer-events-none origin-top-right transition-all duration-200 ease-out flex flex-col p-1.5 md:hidden"
>
  <div class="flex flex-col gap-0.5">
    {
      navigation.map((item) => (
        <a
          href={item.href}
          class="dropdown-nav-link flex items-center gap-3 px-3 py-2.5 text-[15px] font-medium text-slate-200 hover:bg-white/10 rounded-xl transition-colors"
          data-section={item.href}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-slate-400 flex-shrink-0"
            set:html={getNavIcon(item.name)}
          />
          {item.name}
        </a>
      ))
    }
  </div>

  <div class="h-px bg-white/10 my-1.5 mx-2"></div>

  <button
    type="button"
    class="cv-trigger-btn w-full flex items-center justify-between px-3 py-3 text-[15px] font-semibold text-emerald-400 hover:bg-emerald-500/10 rounded-xl transition-colors group"
  >
    <div class="flex items-center gap-3">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline
          points="7 10 12 15 17 10"></polyline><line
          x1="12"
          x2="12"
          y1="15"
          y2="3"></line>
      </svg>
      Minta Akses CV
    </div>
    <span
      class="text-[9px] font-black bg-emerald-500 text-dark-900 px-1.5 py-0.5 rounded-md"
      >PDF</span
    >
  </button>
</div>

<RequestCVModal client:load />

<script>
  const navBar = document.getElementById("nav-bar") as HTMLElement | null;
  const toggleBtn = document.getElementById("dropdown-toggle-btn");
  const dropdown = document.getElementById("mobile-dropdown");
  const overlay = document.getElementById("dropdown-overlay");
  const menuIconOpen = document.getElementById("menu-icon-open");
  const menuIconClose = document.getElementById("menu-icon-close");
  let isMenuOpen = false;

  function handleScroll() {
    if (window.scrollY > 50) {
      if (navBar) {
        navBar.style.backgroundColor = "rgba(10, 10, 10, 0.88)";
        navBar.style.borderColor = "rgba(255, 255, 255, 0.12)";
        navBar.style.boxShadow = "0 8px 32px rgba(0, 0, 0, 0.35)";
      }
    } else {
      if (navBar) {
        navBar.style.backgroundColor = "";
        navBar.style.borderColor = "";
        navBar.style.boxShadow = "";
      }
    }
  }
  window.addEventListener("scroll", handleScroll);

  function closeMenu() {
    isMenuOpen = false;
    dropdown?.classList.remove(
      "opacity-100",
      "scale-100",
      "pointer-events-auto",
    );
    dropdown?.classList.add("opacity-0", "scale-95", "pointer-events-none");
    overlay?.classList.add("hidden");
    menuIconOpen?.classList.remove("hidden");
    menuIconClose?.classList.add("hidden");
  }

  function openMenu() {
    isMenuOpen = true;
    dropdown?.classList.remove("opacity-0", "scale-95", "pointer-events-none");
    dropdown?.classList.add("opacity-100", "scale-100", "pointer-events-auto");
    overlay?.classList.remove("hidden");
    menuIconOpen?.classList.add("hidden");
    menuIconClose?.classList.remove("hidden");
  }

  toggleBtn?.addEventListener("click", () =>
    isMenuOpen ? closeMenu() : openMenu(),
  );
  overlay?.addEventListener("click", closeMenu);

  document.querySelectorAll(".dropdown-nav-link").forEach((link) => {
    link.addEventListener("click", () => closeMenu());
  });

  // Event Listener khusus untuk memanggil Modal React
  document.querySelectorAll(".cv-trigger-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      // Kirim sinyal global agar React Modal terbuka
      window.dispatchEvent(new CustomEvent("open-cv-modal"));
      // Tutup menu dropdown mobile jika sedang terbuka
      closeMenu();
    });
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && isMenuOpen) closeMenu();
  });

  const indicator = document.getElementById(
    "nav-indicator",
  ) as HTMLElement | null;
  const navLinks = document.querySelectorAll<HTMLElement>(".nav-link");

  function moveIndicator(el: HTMLElement) {
    if (!indicator) return;
    const container = el.parentElement as HTMLElement | null;
    if (!container) return;
    const containerRect = container.getBoundingClientRect();
    const elRect = el.getBoundingClientRect();
    indicator.style.left = `${elRect.left - containerRect.left}px`;
    indicator.style.width = `${elRect.width}px`;
    indicator.style.opacity = "1";
  }

  navLinks.forEach((link) => {
    link.addEventListener("mouseenter", () => moveIndicator(link));
  });
  navLinks[0]?.closest("div")?.addEventListener("mouseleave", () => {
    if (indicator) indicator.style.opacity = "0";
  });

  const sections = document.querySelectorAll("section[id]");
  window.addEventListener("scroll", () => {
    let current = "";
    sections.forEach((section) => {
      const el = section as HTMLElement;
      if (window.scrollY >= el.offsetTop - 200) {
        current = section.getAttribute("id") || "";
      }
    });

    navLinks.forEach((link) => {
      const isActive = link.getAttribute("data-section") === `#${current}`;
      link.classList.toggle("text-white", isActive);
      link.classList.toggle("text-slate-400", !isActive);
    });

    document.querySelectorAll(".dropdown-nav-link").forEach((link) => {
      const isActive = link.getAttribute("data-section") === `#${current}`;
      link.classList.toggle("text-white", isActive);
      link.classList.toggle("bg-white/10", isActive);
    });
  });
</script>
