---
import { navigation } from '@/content/site';
---

<header id="header" class="fixed top-0 left-0 right-0 z-50 py-3 transition-all duration-500">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <div
      id="nav-bar"
      class="flex h-14 items-center justify-between gap-3 rounded-2xl bg-dark-900/60 border border-white/10 px-3 sm:px-5 backdrop-blur-xl transition-all duration-300 relative z-50"
    >

      <a href="#hero" class="flex items-center gap-3 group flex-shrink-0">
        <div class="relative w-9 h-9 flex-shrink-0 flex items-center justify-center">

          <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" class="relative w-9 h-9 transform transition-transform duration-500 group-hover:scale-105">
  <defs>
    <linearGradient id="pr-g6x" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#3b82f6"/>
      <stop offset="100%" stop-color="#2dd4bf"/>
    </linearGradient>
    <linearGradient id="pr-g6x-fill" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#3b82f6" stop-opacity="0.12"/>
      <stop offset="100%" stop-color="#2dd4bf" stop-opacity="0.12"/>
    </linearGradient>
  </defs>

  <!-- outer diamond -->
  <path d="M 50 3 L 97 50 L 50 97 L 3 50 Z"
        fill="none" stroke="url(#pr-g6x)" stroke-width="2" opacity="0.4"/>
  <!-- inner diamond, slightly rotated/offset -->
  <path d="M 50 16 L 84 50 L 50 84 L 16 50 Z"
        fill="url(#pr-g6x-fill)" stroke="url(#pr-g6x)" stroke-width="1.5" opacity="0.55"/>

  <!-- P-R monoline -->
  <path d="M 33 32 L 33 68 M 33 32 L 55 32 Q 69 32 69 43 Q 69 54 55 54 L 33 54 M 47 54 L 67 72"
        fill="none" stroke="url(#pr-g6x)" stroke-width="7" stroke-linecap="round" stroke-linejoin="round"/>

  <!-- outer diamond vertex nodes -->
  <circle cx="50" cy="3"  r="3" fill="#2dd4bf"/>
  <circle cx="97" cy="50" r="3" fill="#3b82f6"/>
  <circle cx="50" cy="97" r="3" fill="#2dd4bf"/>
  <circle cx="3"  cy="50" r="3" fill="#60a5fa"/>

  <!-- connector lines from outer to inner diamond -->
  <g stroke="#2dd4bf" stroke-width="1.2" opacity="0.5" fill="none">
    <path d="M 50 3 L 50 16"/>
    <path d="M 97 50 L 84 50"/>
    <path d="M 50 97 L 50 84"/>
    <path d="M 3 50 L 16 50"/>
  </g>

  <!-- inner diamond vertex nodes -->
  <circle cx="50" cy="16" r="2" fill="#60a5fa" opacity="0.8"/>
  <circle cx="84" cy="50" r="2" fill="#60a5fa" opacity="0.8"/>
  <circle cx="50" cy="84" r="2" fill="#60a5fa" opacity="0.8"/>
  <circle cx="16" cy="50" r="2" fill="#60a5fa" opacity="0.8"/>

  <!-- small rotation-accent ticks on outer diamond edges -->
  <g stroke="#3b82f6" stroke-width="1.5" opacity="0.35" fill="none" stroke-linecap="round">
    <path d="M 73 26 L 78 22"/>
    <path d="M 73 74 L 78 78"/>
    <path d="M 27 74 L 22 78"/>
    <path d="M 27 26 L 22 22"/>
  </g>
</svg>
        </div>

        <span class="text-white font-bold text-lg hidden sm:block font-display tracking-tight">
          Pramudya<span class="text-primary-400 font-black">.site</span>
        </span>
      </a>

      <nav class="hidden md:flex items-center flex-1 justify-center">
        <div class="relative flex items-center gap-0.5">
          <div
            id="nav-indicator"
            class="absolute h-8 rounded-xl bg-primary-500/15 border border-primary-500/30 transition-all duration-300 pointer-events-none opacity-0"
          ></div>
          {navigation.map((item) => (
            <a
              href={item.href}
              class="nav-link relative z-10 px-4 py-1.5 text-sm font-medium text-slate-400 hover:text-white rounded-xl transition-colors duration-200 whitespace-nowrap"
              data-section={item.href}
            >
              {item.name}
            </a>
          ))}
        </div>
      </nav>

      <div class="hidden md:flex items-center gap-3 flex-shrink-0">
        <div class="flex items-center gap-2 text-xs text-slate-400">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
          </span>
          <span class="hidden lg:inline">Available</span>
        </div>
        <a
          href="#contact"
          class="relative group inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-primary-600 to-primary-500 px-5 py-2 text-sm font-semibold text-white overflow-hidden transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-primary-500/30"
        >
          <span class="absolute inset-0 -translate-x-full group-hover:translate-x-full transition-transform duration-700 bg-gradient-to-r from-transparent via-white/15 to-transparent skew-x-12"></span>
          <span class="relative">Hubungi Saya</span>
          <svg class="relative transition-transform duration-300 group-hover:translate-x-0.5" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
      </div>

      <button
        id="sidebar-toggle-btn"
        class="md:hidden relative z-50 w-9 h-9 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-slate-300 hover:text-white hover:bg-white/10 transition-all duration-300"
        aria-label="Toggle sidebar menu"
      >
        <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" x2="20" y1="6"  y2="6"/><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="18" y2="18"/>
        </svg>
        <svg id="menu-icon-close" class="hidden" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
        </svg>
      </button>

    </div>
  </div>
</header>

<div
  id="sidebar-overlay"
  class="fixed inset-0 z-40 bg-black/60 backdrop-blur-md opacity-0 pointer-events-none transition-opacity duration-500 md:hidden"
></div>

<aside
  id="sidebar"
  class="fixed top-0 right-0 h-[100dvh] w-3/4 max-w-[320px] min-w-[260px] z-40 bg-[#0a0a0a]/98 backdrop-blur-3xl border-l border-white/5 rounded-l-3xl shadow-2xl transform translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] flex flex-col pt-[88px] overflow-hidden md:hidden"
>
  <div class="absolute top-0 right-0 w-72 h-72 bg-primary-500/10 rounded-full blur-[80px] pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-56 h-56 bg-accent-500/5 rounded-full blur-[60px] pointer-events-none"></div>

  <div class="relative flex-1 overflow-y-auto px-8 pb-8 pt-4 flex flex-col scrollbar-hide">

    <div class="flex items-center gap-3 mb-10">
      <span class="relative flex h-2.5 w-2.5">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-500"></span>
      </span>
      <span class="text-xs font-medium tracking-[0.2em] text-slate-400 uppercase">Open to Work</span>
    </div>

    <nav class="flex flex-col gap-2 flex-1">
      {navigation.map((item, i) => (
        <a
          href={item.href}
          class="sidebar-nav-link group flex items-center gap-4 py-3 text-3xl sm:text-4xl font-bold text-slate-400 hover:text-white transition-all duration-300"
          style={`transition-delay: ${i * 40}ms`}
          data-section={item.href}
        >
          <span class="w-0 group-hover:w-3 h-1 rounded-full bg-primary-500 transition-all duration-300"></span>
          <span class="transform group-hover:translate-x-2 transition-transform duration-300">{item.name}</span>
        </a>
      ))}
    </nav>

    <div class="mt-8">
      <a
        href="#contact"
        class="sidebar-contact-btn group flex items-center justify-center gap-2 w-full rounded-2xl bg-gradient-to-r from-primary-600 to-primary-500 px-6 py-4 text-sm font-semibold text-white shadow-lg shadow-primary-500/20 hover:shadow-primary-500/40 hover:-translate-y-0.5 transition-all duration-300"
      >
        <span>Hubungi Saya</span>
        <svg class="transition-transform duration-300 group-hover:translate-x-1" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</aside>

<script>
  const navBar            = document.getElementById('nav-bar') as HTMLElement | null;
  const sidebarToggleBtn  = document.getElementById('sidebar-toggle-btn');
  const sidebar           = document.getElementById('sidebar');
  const sidebarOverlay    = document.getElementById('sidebar-overlay');
  const menuIconOpen      = document.getElementById('menu-icon-open');
  const menuIconClose     = document.getElementById('menu-icon-close');
  let   sidebarOpen       = false;

  // ── Scroll: darken & lift the pill bar ───────────────────────────────────
  function handleScroll() {
    if (sidebarOpen) return;
    if (window.scrollY > 50) {
      if (navBar) {
        navBar.style.backgroundColor = 'rgba(10, 10, 10, 0.88)';
        navBar.style.borderColor     = 'rgba(255, 255, 255, 0.12)';
        navBar.style.boxShadow       = '0 8px 32px rgba(0, 0, 0, 0.35)';
      }
    } else {
      if (navBar) {
        navBar.style.backgroundColor = '';
        navBar.style.borderColor     = '';
        navBar.style.boxShadow       = '';
      }
    }
  }
  window.addEventListener('scroll', handleScroll);

  // ── Sidebar open / close ─────────────────────────────────────────────────
  function closeSidebar() {
    sidebarOpen = false;
    sidebar?.classList.add('translate-x-full');
    sidebarOverlay?.classList.add('opacity-0', 'pointer-events-none');
    sidebarOverlay?.classList.remove('opacity-100', 'pointer-events-auto');
    menuIconOpen?.classList.remove('hidden');
    menuIconClose?.classList.add('hidden');
    document.body.style.overflow = '';
    
    handleScroll();

    document.querySelectorAll('.sidebar-nav-link').forEach((link) => {
      link.classList.add('opacity-0', 'translate-x-4');
      link.classList.remove('opacity-100', 'translate-x-0');
    });
  }

  function openSidebar() {
    sidebarOpen = true;
    sidebar?.classList.remove('translate-x-full');
    sidebarOverlay?.classList.remove('opacity-0', 'pointer-events-none');
    sidebarOverlay?.classList.add('opacity-100', 'pointer-events-auto');
    menuIconOpen?.classList.add('hidden');
    menuIconClose?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';

    if (navBar) {
      navBar.style.backgroundColor = 'rgba(10, 10, 10, 0.98)';
      navBar.style.borderColor     = 'rgba(255, 255, 255, 0.15)';
      navBar.style.boxShadow       = '0 8px 32px rgba(0, 0, 0, 0.5)';
    }

    document.querySelectorAll('.sidebar-nav-link').forEach((link, i) => {
      setTimeout(() => {
        link.classList.add('opacity-100', 'translate-x-0');
        link.classList.remove('opacity-0', 'translate-x-4');
      }, 100 + i * 40);
    });
  }

  sidebarToggleBtn?.addEventListener('click', () => sidebarOpen ? closeSidebar() : openSidebar());
  sidebarOverlay?.addEventListener('click', closeSidebar);

  document.querySelectorAll('.sidebar-nav-link').forEach(link => {
    link.addEventListener('click', () => closeSidebar());
  });
  document.querySelector('.sidebar-contact-btn')?.addEventListener('click', () => closeSidebar());
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && sidebarOpen) closeSidebar();
  });

  // ── Sliding nav indicator (Desktop hover) ────────────────────────────────
  const indicator = document.getElementById('nav-indicator') as HTMLElement | null;
  const navLinks  = document.querySelectorAll<HTMLElement>('.nav-link');

  function moveIndicator(el: HTMLElement) {
    if (!indicator) return;
    const container = el.parentElement as HTMLElement | null;
    if (!container) return;
    const containerRect = container.getBoundingClientRect();
    const elRect        = el.getBoundingClientRect();
    indicator.style.left    = `${elRect.left - containerRect.left}px`;
    indicator.style.width   = `${elRect.width}px`;
    indicator.style.opacity = '1';
  }

  navLinks.forEach(link => {
    link.addEventListener('mouseenter', () => moveIndicator(link));
  });
  navLinks[0]?.closest('div')?.addEventListener('mouseleave', () => {
    if (indicator) indicator.style.opacity = '0';
  });

  // ── Active section highlighting ───────────────────────────────────────────
  const sections = document.querySelectorAll('section[id]');

  window.addEventListener('scroll', () => {
    let current = '';
    sections.forEach(section => {
      const el = section as HTMLElement;
      if (window.scrollY >= el.offsetTop - 200) {
        current = section.getAttribute('id') || '';
      }
    });

    navLinks.forEach(link => {
      const isActive = link.getAttribute('data-section') === `#${current}`;
      link.classList.toggle('text-white',     isActive);
      link.classList.toggle('text-slate-400', !isActive);
    });

    document.querySelectorAll('.sidebar-nav-link').forEach(link => {
      const isActive = link.getAttribute('data-section') === `#${current}`;
      link.classList.toggle('text-white',     isActive);
      link.classList.toggle('text-slate-400', !isActive);
    });
  });

  // Initialize sidebar links (hidden for entrance animation)
  document.querySelectorAll('.sidebar-nav-link').forEach((link) => {
    link.classList.add('opacity-0', 'translate-x-4');
  });
</script>