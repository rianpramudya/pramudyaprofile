---
import { navigation } from '@/content/site';
---

<header id="header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 md:h-20 items-center justify-between gap-4">

      <!-- Logo -->
      <a href="#hero" class="flex items-center gap-3 group flex-shrink-0">
        <div class="relative w-10 h-10 flex-shrink-0">
          <div class="absolute inset-0 rounded-xl bg-[radial-gradient(circle_at_30%_30%,rgba(20,184,166,0.55),transparent_65%)] blur-md group-hover:opacity-80 opacity-60 transition-opacity duration-300"></div>
          <div class="relative w-10 h-10 rounded-xl bg-gradient-to-br from-[#0d1f1e] to-[#060e0d] border border-teal-500/20 flex items-center justify-center font-bold shadow-lg font-mono" style="font-size: 11px; letter-spacing: -0.5px; color: #5eead4; box-shadow: inset 0 1px 0 rgba(20,184,166,0.12), 0 0 18px rgba(20,184,166,0.15);">
            &lt;R/&gt;
          </div>
        </div>
        <span class="text-white font-bold text-lg hidden sm:block font-display tracking-tight">
          Pramudyarian<span class="text-primary-400">.</span>
        </span>
      </a>

      <!-- Desktop Navigation — pill container (hidden on mobile) -->
      <nav class="hidden md:flex items-center">
        <div class="relative flex items-center gap-1 rounded-2xl bg-white/5 border border-white/10 px-2 py-1.5 backdrop-blur-sm">
          <div id="nav-indicator" class="absolute h-8 rounded-xl bg-primary-500/15 border border-primary-500/30 transition-all duration-300 pointer-events-none"></div>
          {navigation.map((item) => (
            <a
              href={item.href}
              class="nav-link relative z-10 px-4 py-1.5 text-sm font-medium text-slate-400 hover:text-white rounded-xl transition-colors duration-200 whitespace-nowrap"
              data-section={item.href}
            >
              {item.name}
            </a>
          ))}
        </div>
      </nav>

      <!-- CTA Button (Desktop only) -->
      <div class="hidden md:flex items-center gap-3 flex-shrink-0">
        <div class="flex items-center gap-2 text-xs text-slate-400">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
          </span>
          <span class="hidden lg:inline">Available</span>
        </div>
        <a
          href="#contact"
          class="relative group inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-primary-600 to-primary-500 px-5 py-2.5 text-sm font-semibold text-white overflow-hidden transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-primary-500/30"
        >
          <span class="absolute inset-0 -translate-x-full group-hover:translate-x-full transition-transform duration-700 bg-gradient-to-r from-transparent via-white/15 to-transparent skew-x-12"></span>
          <span class="relative">Hubungi Saya</span>
          <svg class="relative transition-transform duration-300 group-hover:translate-x-0.5" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Hamburger Menu Button (Mobile only) -->
      <button
        id="sidebar-toggle-btn"
        class="md:hidden relative z-50 w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-slate-300 hover:text-white hover:bg-white/10 transition-all duration-300"
        aria-label="Toggle sidebar menu"
      >
        <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" x2="20" y1="6" y2="6"/>
          <line x1="4" x2="20" y1="12" y2="12"/>
          <line x1="4" x2="20" y1="18" y2="18"/>
        </svg>
        <svg id="menu-icon-close" class="hidden" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 6 6 18"/>
          <path d="m6 6 12 12"/>
        </svg>
      </button>

    </div>
  </div>
</header>

<!-- ═══════════════════════════════════════════ -->
<!-- SIDEBAR MENU (Right Side Panel - Mobile Only) -->
<!-- ═══════════════════════════════════════════ -->

<!-- Overlay backdrop -->
<div id="sidebar-overlay" class="fixed inset-0 z-40 bg-black/40 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-500 md:hidden"></div>

<!-- Sidebar Panel -->
<aside id="sidebar" class="fixed top-0 right-0 h-[70vh] w-1/2 max-w-[400px] min-w-[280px] z-40 bg-[#0a0a0a]/95 backdrop-blur-2xl border-l border-white/5 rounded-bl-3xl transform translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] overflow-y-auto overflow-x-hidden md:hidden scrollbar-hide">

  <!-- Decorative gradient blobs -->
  <div class="absolute top-0 right-0 w-72 h-72 bg-primary-500/5 rounded-full blur-[80px] pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-56 h-56 bg-accent-500/3 rounded-full blur-[60px] pointer-events-none"></div>

  <!-- Sidebar Content -->
  <div class="relative flex flex-col px-8 pt-20 pb-8 min-h-full">

    <!-- Status Indicator -->
    <div class="flex items-center gap-3 mb-10">
      <span class="relative flex h-2.5 w-2.5">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-500"></span>
      </span>
      <span class="text-xs font-medium tracking-[0.2em] text-slate-400 uppercase">Open to Work</span>
    </div>

    <!-- Navigation Links -->
    <nav class="flex flex-col gap-2 flex-1">
      {navigation.map((item, i) => (
        <a
          href={item.href}
          class="sidebar-nav-link group flex items-center gap-4 py-2 text-3xl sm:text-4xl font-bold text-slate-500 hover:text-white transition-all duration-300"
          style={`transition-delay: ${i * 50}ms`}
          data-section={item.href}
        >
          <span class="w-0 group-hover:w-3 h-1 rounded-full bg-primary-500 transition-all duration-300"></span>
          <span class="transform group-hover:translate-x-2 transition-transform duration-300">{item.name}</span>
        </a>
      ))}
    </nav>

    <!-- CTA Button di bawah -->
    <div class="mt-6">
      <a
        href="#contact"
        class="sidebar-contact-btn group flex items-center justify-center gap-2 w-full rounded-2xl bg-gradient-to-r from-primary-600 to-primary-500 px-6 py-3.5 text-sm font-semibold text-white shadow-lg shadow-primary-500/20 hover:shadow-primary-500/40 hover:-translate-y-0.5 transition-all duration-300"
      >
        <span>Hubungi Saya</span>
        <svg class="transition-transform duration-300 group-hover:translate-x-1" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</aside>

<script>
  const header = document.getElementById('header');
  const sidebarToggleBtn = document.getElementById('sidebar-toggle-btn');
  const sidebar = document.getElementById('sidebar');
  const sidebarOverlay = document.getElementById('sidebar-overlay');
  const menuIconOpen = document.getElementById('menu-icon-open');
  const menuIconClose = document.getElementById('menu-icon-close');
  let sidebarOpen = false;

  // ── Scroll effect for header
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('bg-dark-900/80', 'backdrop-blur-xl', 'border-b', 'border-slate-800/50');
    } else {
      header?.classList.remove('bg-dark-900/80', 'backdrop-blur-xl', 'border-b', 'border-slate-800/50');
    }
  });

  // ── Sidebar Toggle Function
  function closeSidebar() {
    sidebarOpen = false;
    sidebar?.classList.add('translate-x-full');
    sidebarOverlay?.classList.add('opacity-0', 'pointer-events-none');
    sidebarOverlay?.classList.remove('opacity-100', 'pointer-events-auto');
    menuIconOpen?.classList.remove('hidden');
    menuIconClose?.classList.add('hidden');
    document.body.style.overflow = '';

    // Reset nav link animations
    document.querySelectorAll('.sidebar-nav-link').forEach((link) => {
      link.classList.add('opacity-0', 'translate-x-4');
      link.classList.remove('opacity-100', 'translate-x-0');
    });
  }

  function openSidebar() {
    sidebarOpen = true;
    sidebar?.classList.remove('translate-x-full');
    sidebarOverlay?.classList.remove('opacity-0', 'pointer-events-none');
    sidebarOverlay?.classList.add('opacity-100', 'pointer-events-auto');
    menuIconOpen?.classList.add('hidden');
    menuIconClose?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';

    // Animate nav links staggered
    document.querySelectorAll('.sidebar-nav-link').forEach((link, i) => {
      setTimeout(() => {
        link.classList.add('opacity-100', 'translate-x-0');
        link.classList.remove('opacity-0', 'translate-x-4');
      }, 100 + i * 50);
    });
  }

  function toggleSidebar() {
    if (sidebarOpen) {
      closeSidebar();
    } else {
      openSidebar();
    }
  }

  sidebarToggleBtn?.addEventListener('click', toggleSidebar);
  sidebarOverlay?.addEventListener('click', closeSidebar);

  // ── Handle nav link clicks — close sidebar then let browser handle anchor
  document.querySelectorAll('.sidebar-nav-link').forEach(link => {
    link.addEventListener('click', (e) => {
      closeSidebar();
    });
  });

  // ── Handle contact button click in sidebar
  document.querySelector('.sidebar-contact-btn')?.addEventListener('click', () => {
    closeSidebar();
  });

  // ── Keyboard support (Escape to close)
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && sidebarOpen) {
      closeSidebar();
    }
  });

  // ── Sliding nav indicator (Desktop only)
  const indicator = document.getElementById('nav-indicator') as HTMLElement | null;
  const navLinks = document.querySelectorAll<HTMLElement>('.nav-link');

  function moveIndicator(el: HTMLElement) {
    if (!indicator) return;
    const navContainer = el.closest('nav');
    if (!navContainer) return;
    const containerRect = navContainer.querySelector('div')?.getBoundingClientRect();
    const elRect = el.getBoundingClientRect();
    if (!containerRect) return;
    indicator.style.left = `${elRect.left - containerRect.left}px`;
    indicator.style.width = `${elRect.width}px`;
    indicator.style.opacity = '1';
  }

  function hideIndicator() {
    if (!indicator) return;
    indicator.style.opacity = '0';
  }

  navLinks.forEach(link => {
    link.addEventListener('mouseenter', () => moveIndicator(link));
  });

  document.querySelector('nav')?.addEventListener('mouseleave', hideIndicator);

  // ── Active section highlighting
  const sections = document.querySelectorAll('section[id]');

  window.addEventListener('scroll', () => {
    let current = '';
    sections.forEach(section => {
      const el = section as HTMLElement;
      if (window.scrollY >= el.offsetTop - 200) {
        current = section.getAttribute('id') || '';
      }
    });

    // Update desktop nav links
    navLinks.forEach(link => {
      const isActive = link.getAttribute('data-section') === `#${current}`;
      link.classList.toggle('text-white', isActive);
      link.classList.toggle('text-slate-400', !isActive);
    });

    // Update sidebar nav links
    document.querySelectorAll('.sidebar-nav-link').forEach(link => {
      const isActive = link.getAttribute('data-section') === `#${current}`;
      link.classList.toggle('text-white', isActive);
      link.classList.toggle('text-slate-500', !isActive);
    });
  });

  // Initialize sidebar links with hidden state for animation
  document.querySelectorAll('.sidebar-nav-link').forEach((link) => {
    link.classList.add('opacity-0', 'translate-x-4');
  });
</script>