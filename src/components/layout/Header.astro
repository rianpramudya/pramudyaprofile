---
import { navigation } from "@/content/site";
import RequestCVModal from "@/components/ui/RequestCVModal.jsx";
import MobileNav from "@/components/layout/MobileNav.jsx";
import { dictionary } from "@/i18n/dictionary";
import type { Lang } from "@/i18n/dictionary";

function getLangFromUrl(url: URL): Lang {
  const q = url.searchParams.get("lang");
  if (q === "en" || q === "id") return q;
  return "id";
}

const lang = getLangFromUrl(Astro.url);

function ts(key: string): string {
  const dict = dictionary[lang] as Record<string, string | string[]>;
  const val = dict[key];
  if (typeof val === "string") return val;
  return key;
}
---

<header id="header-wrapper">
  <nav id="nav">
    <a href="#hero" class="nav-brand group">
      <svg
        viewBox="0 0 100 100"
        xmlns="http://www.w3.org/2000/svg"
        class="brand-logo"
      >
        <defs>
          <linearGradient id="pr-g6x" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="var(--c)"></stop>
            <stop offset="100%" stop-color="var(--v)"></stop>
          </linearGradient>
        </defs>
        <path
          d="M 50 3 L 97 50 L 50 97 L 3 50 Z"
          fill="none"
          stroke="url(#pr-g6x)"
          stroke-width="2"
          opacity="0.4"></path>
        <path
          d="M 50 16 L 84 50 L 50 84 L 16 50 Z"
          fill="none"
          stroke="url(#pr-g6x)"
          stroke-width="1.5"
          opacity="0.55"></path>
        <path
          d="M 33 32 L 33 68 M 33 32 L 55 32 Q 69 32 69 43 Q 69 54 55 54 L 33 54 M 47 54 L 67 72"
          fill="none"
          stroke="url(#pr-g6x)"
          stroke-width="7"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
      <span>// <em>PRAMUDYA</em>.DEV</span>
    </a>

    <ul class="nav-links">
      {
        navigation.map((item) => (
          <li>
            <a href={item.href} data-section={item.href} data-i18n={item.key}>
              {ts(item.key)}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="nav-right">
      <div class="nav-avail">
        <div class="dot"></div>
        <span data-i18n="availability.available"
          >{ts("availability.available")}</span
        >
      </div>

      <div
        class="theme-toggle lang-switcher"
        role="group"
        aria-label="Language"
      >
        <button
          type="button"
          id="langID"
          class="theme-btn lang-btn text-xs font-mono"
          data-lang="id">ID</button
        >
        <button
          type="button"
          id="langEN"
          class="theme-btn lang-btn text-xs font-mono"
          data-lang="en">EN</button
        >
      </div>

      <div class="theme-toggle" role="group" aria-label="Theme">
        <button
          class="theme-btn"
          id="themeLight"
          type="button"
          aria-label="Light mode"
          aria-pressed="false"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><circle cx="12" cy="12" r="4"></circle><path
              d="M12 2v2M12 20v2M4.93 4.93l1.4 1.4M17.66 17.66l1.4 1.4M2 12h2M20 12h2M6.34 17.66l-1.4 1.4M19.07 4.93l-1.4 1.4"
            ></path></svg
          >
        </button>
        <button
          class="theme-btn act"
          id="themeDark"
          type="button"
          aria-label="Dark mode"
          aria-pressed="true"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"
            ></path></svg
          >
        </button>
      </div>

      <button type="button" class="nav-cv-btn cv-trigger-btn">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" x2="12" y1="15" y2="3"></line>
        </svg>
        <span>CV</span>
      </button>
    </div>
  </nav>

  <MobileNav client:load />
  <RequestCVModal client:load />
</header>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 200;
    padding: 1rem clamp(1.2rem, 4vw, 2.5rem);
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid transparent;
    transition:
      background 0.3s,
      border-color 0.3s;
  }

  nav.scrolled {
    background: var(--nav-bg);
    backdrop-filter: blur(24px);
    border-bottom-color: transparent;
  }

  nav.scrolled::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 1px;
    background: linear-gradient(90deg, var(--c), var(--v));
    opacity: 0.45;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: clamp(0.4rem, 1vw, 0.75rem);
    font-family: "JetBrains Mono", "Fira Code", "Courier New", monospace;
    font-size: clamp(0.65rem, 1.2vw, 0.72rem);
    color: var(--t2);
    letter-spacing: 0.06em;
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.25s ease;
  }

  .nav-brand:hover {
    color: var(--v);
  }

  .nav-brand .brand-logo {
    width: 28px;
    height: 28px;
    transition: transform 0.4s ease;
  }

  .nav-brand:hover .brand-logo {
    transform: scale(1.1) rotate(3deg);
  }

  .nav-brand em {
    font-style: normal;
    color: var(--v);
  }

  .nav-links {
    display: flex;
    gap: clamp(1rem, 2vw, 2.25rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    position: relative;
    font-family: "JetBrains Mono", "Fira Code", "Courier New", monospace;
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--t2);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-links a::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -6px;
    height: 1px;
    background: var(--v);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--t1);
  }

  .nav-links a:hover::after,
  .nav-links a.active::after {
    transform: scaleX(1);
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: clamp(0.5rem, 1.5vw, 1.1rem);
  }

  .nav-avail {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: "JetBrains Mono", "Fira Code", "Courier New", monospace;
    font-size: 0.6rem;
    color: var(--v);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    white-space: nowrap;
    background: color-mix(in srgb, var(--v) 10%, transparent);
    padding: 0.3rem 0.6rem;
    border-radius: 2px;
  }

  .dot {
    width: 6px;
    height: 6px;
    background: var(--v);
    border-radius: 2px;
    animation: pulse-dot 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    flex-shrink: 0;
  }

  @keyframes pulse-dot {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.35;
    }
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    gap: 2px;
    background: var(--bg-3);
    border: 1px solid var(--border-2);
    border-radius: 2px;
    padding: 3px;
    flex-shrink: 0;
  }

  .theme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 2px;
    background: transparent;
    border: none;
    color: var(--t3);
    cursor: pointer;
    transition:
      background 0.2s,
      color 0.2s;
  }

  .theme-btn.lang-btn {
    width: auto;
    padding: 0 8px;
    border-radius: 2px;
    font-size: 0.6rem;
    letter-spacing: 0.04em;
  }

  .theme-btn svg {
    width: 14px;
    height: 14px;
    display: block;
  }

  .theme-btn:hover:not(.act) {
    color: var(--v);
  }

  .theme-btn.act {
    background: var(--vd);
    color: var(--v);
  }

  .nav-cv-btn {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.9rem;
    background: var(--v);
    color: var(--bg);
    font-family: "JetBrains Mono", "Fira Code", "Courier New", monospace;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    /* Notch 12px (konsisten dengan Projects/Contact/Skills) */
    clip-path: polygon(
      0 0,
      100% 0,
      100% calc(100% - 12px),
      calc(100% - 12px) 100%,
      0 100%
    );
    transition: box-shadow 0.3s;
  }

  .nav-cv-btn span,
  .nav-cv-btn svg {
    position: relative;
    z-index: 1;
  }

  .nav-cv-btn::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.2);
    transform: translateY(100%);
    transition: transform 0.3s ease;
  }

  .nav-cv-btn:hover::after {
    transform: translateY(0);
  }

  .nav-cv-btn:hover {
    box-shadow: 0 0 20px var(--shadow-v);
  }

  .nav-cv-btn svg {
    width: 13px;
    height: 13px;
  }

  @media (max-width: 1150px) {
    .nav-avail span {
      display: none;
    }
  }

  @media (max-width: 980px) {
    nav {
      padding: 1rem 1.2rem;
    }

    .nav-links,
    .nav-avail,
    .theme-toggle,
    .nav-cv-btn {
      display: none;
    }
  }
</style>

<script>
  import { setLang, getLang } from "@/i18n/index";

  const nav = document.getElementById("nav");
  window.addEventListener(
    "scroll",
    () => {
      if (nav) nav.classList.toggle("scrolled", window.scrollY > 50);
    },
    {
      passive: true,
    },
  );

  const STORAGE_THEME = "pramudya-theme";
  const root = document.documentElement;
  const themeMeta = document.querySelector('meta[name="theme-color"]');

  const btnsLight = [document.getElementById("themeLight")];
  const btnsDark = [document.getElementById("themeDark")];

  function setTheme(mode) {
    root.classList.add("theme-transition");
    if (mode === "light") root.setAttribute("data-theme", "light");
    else root.removeAttribute("data-theme");

    btnsLight.forEach((btn) => btn?.classList.toggle("act", mode === "light"));
    btnsDark.forEach((btn) => btn?.classList.toggle("act", mode === "dark"));

    if (themeMeta) {
      themeMeta.setAttribute(
        "content",
        mode === "light" ? "#f7f5fb" : "#06060a",
      );
    }

    localStorage.setItem(STORAGE_THEME, mode);
    setTimeout(() => root.classList.remove("theme-transition"), 450);
  }

  const savedTheme = localStorage.getItem(STORAGE_THEME) || "dark";
  setTheme(savedTheme);

  btnsLight.forEach((btn) =>
    btn?.addEventListener("click", () => setTheme("light")),
  );
  btnsDark.forEach((btn) =>
    btn?.addEventListener("click", () => setTheme("dark")),
  );

  const btnsID = [document.getElementById("langID")];
  const btnsEN = [document.getElementById("langEN")];

  function updateLangUI(lang) {
    btnsID.forEach((btn) => btn?.classList.toggle("act", lang === "id"));
    btnsEN.forEach((btn) => btn?.classList.toggle("act", lang === "en"));
  }

  const currentLang = getLang();
  updateLangUI(currentLang);

  btnsID.forEach((btn) =>
    btn?.addEventListener("click", () => {
      setLang("id");
      updateLangUI("id");
    }),
  );

  btnsEN.forEach((btn) =>
    btn?.addEventListener("click", () => {
      setLang("en");
      updateLangUI("en");
    }),
  );

  window.addEventListener("langchange", ((e: CustomEvent) => {
    updateLangUI(e.detail);
  }) as EventListener);

  document.querySelectorAll(".cv-trigger-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      window.dispatchEvent(new CustomEvent("open-cv-modal"));
    });
  });
</script>
