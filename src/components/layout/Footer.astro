---
import { site, socialLinks } from '@/content/site';
const currentYear = new Date().getFullYear();
const footerLinks = [
  { name: 'Beranda', href: '#hero' },
  { name: 'Tentang', href: '#about' },
  { name: 'Skills', href: '#skills' },
  { name: 'Proyek', href: '#projects' },
  { name: 'Kontak', href: '#contact' },
];
---

<footer class="relative bg-[#04040f] overflow-hidden border-t border-white/5">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-emerald-500/30 to-transparent"></div>

  <div class="relative border-b border-slate-800/60 overflow-hidden">
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
      <div class="w-[600px] h-[300px] bg-emerald-500/10 rounded-full blur-[100px]"></div>
      <div class="absolute w-[300px] h-[200px] bg-cyan-500/10 rounded-full blur-[80px] translate-y-10"></div>
    </div>
    
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-48 h-px bg-gradient-to-r from-transparent via-cyan-500/60 to-transparent"></div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 md:py-20 text-center">
      <div class="inline-flex items-center gap-2 rounded-full bg-emerald-500/10 border border-emerald-500/25 px-4 py-1.5 mb-6 backdrop-blur-sm">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
        </span>
        <span class="text-xs font-semibold text-emerald-300 tracking-widest uppercase">Tersedia untuk Proyek Baru</span>
      </div>

      <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-white tracking-tight leading-tight mb-4 font-display">
        Mari Wujudkan <span class="bg-gradient-to-r from-emerald-400 via-teal-400 to-cyan-400 bg-clip-text text-transparent">Ide Anda</span>
      </h2>
      <p class="text-slate-400 text-sm md:text-base max-w-md mx-auto leading-relaxed mb-8">
        Punya proyek menarik? Saya siap berkolaborasi untuk membangun solusi yang berdampak.
      </p>

      <div class="flex items-center justify-center gap-3 flex-wrap">
        <a
          href="#contact"
          class="relative group inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-emerald-600 to-teal-500 px-6 py-3 text-sm font-semibold text-white overflow-hidden transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-emerald-500/30"
        >
          <span class="absolute inset-0 -translate-x-full group-hover:translate-x-full transition-transform duration-700 bg-gradient-to-r from-transparent via-white/20 to-transparent skew-x-12"></span>
          <span class="relative">Mulai Diskusi</span>
          <svg class="relative transition-transform duration-300 group-hover:translate-x-0.5" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href={site.github}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-xl border border-slate-700/60 bg-white/5 backdrop-blur-sm px-6 py-3 text-sm font-medium text-slate-300 hover:text-white hover:border-slate-500 hover:bg-white/10 transition-all duration-300 hover:-translate-y-0.5"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          Lihat GitHub
        </a>
      </div>
    </div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-12 md:pt-16 z-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8">

      <div class="space-y-4">
        <a href="#hero" class="flex items-center gap-3 group">
          <div class="relative w-10 h-10 flex-shrink-0 flex items-center justify-center">
            
            <div class="absolute inset-0 bg-emerald-500/20 rounded-full blur-md opacity-60 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
            
            <svg
              viewBox="0 0 100 100"
              xmlns="http://www.w3.org/2000/svg"
              class="relative w-9 h-9 transform transition-transform duration-500 group-hover:scale-105"
              aria-hidden="true"
            >
              <defs>
                <linearGradient id="footer-pr-g6x" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#3b82f6"></stop>
                  <stop offset="100%" stop-color="#2dd4bf"></stop>
                </linearGradient>
                <linearGradient id="footer-pr-g6x-fill" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#3b82f6" stop-opacity="0.12"></stop>
                  <stop offset="100%" stop-color="#2dd4bf" stop-opacity="0.12"></stop>
                </linearGradient>
              </defs>

              <path d="M 50 3 L 97 50 L 50 97 L 3 50 Z" fill="none" stroke="url(#footer-pr-g6x)" stroke-width="2" opacity="0.4"></path>
              <path d="M 50 16 L 84 50 L 50 84 L 16 50 Z" fill="url(#footer-pr-g6x-fill)" stroke="url(#footer-pr-g6x)" stroke-width="1.5" opacity="0.55"></path>
              <path d="M 33 32 L 33 68 M 33 32 L 55 32 Q 69 32 69 43 Q 69 54 55 54 L 33 54 M 47 54 L 67 72" fill="none" stroke="url(#footer-pr-g6x)" stroke-width="7" stroke-linecap="round" stroke-linejoin="round"></path>
              
              <circle cx="50" cy="3" r="3" fill="#2dd4bf"></circle>
              <circle cx="97" cy="50" r="3" fill="#3b82f6"></circle>
              <circle cx="50" cy="97" r="3" fill="#2dd4bf"></circle>
              <circle cx="3" cy="50" r="3" fill="#60a5fa"></circle>

              <g stroke="#2dd4bf" stroke-width="1.2" opacity="0.5" fill="none">
                <path d="M 50 3 L 50 16"></path>
                <path d="M 97 50 L 84 50"></path>
                <path d="M 50 97 L 50 84"></path>
                <path d="M 3 50 L 16 50"></path>
              </g>

              <circle cx="50" cy="16" r="2" fill="#60a5fa" opacity="0.8"></circle>
              <circle cx="84" cy="50" r="2" fill="#60a5fa" opacity="0.8"></circle>
              <circle cx="50" cy="84" r="2" fill="#60a5fa" opacity="0.8"></circle>
              <circle cx="16" cy="50" r="2" fill="#60a5fa" opacity="0.8"></circle>

              <g stroke="#3b82f6" stroke-width="1.5" opacity="0.35" fill="none" stroke-linecap="round">
                <path d="M 73 26 L 78 22"></path>
                <path d="M 73 74 L 78 78"></path>
                <path d="M 27 74 L 22 78"></path>
                <path d="M 27 26 L 22 22"></path>
              </g>
            </svg>
          </div>
          
          <span class="text-white font-bold text-lg font-display tracking-tight">
            Pramudya<span class="text-emerald-400 font-black">.site</span>
          </span>
        </a>

        <p class="text-slate-500 text-sm leading-relaxed max-w-xs">
          {site.description}
        </p>

        <div class="flex items-center gap-2.5 pt-1">
          {socialLinks.map(link => (
            <a
              href={link.href}
              target={link.href.startsWith('http') ? '_blank' : undefined}
              rel="noopener noreferrer"
              class="w-9 h-9 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-slate-400 hover:text-white hover:border-emerald-500/40 hover:bg-emerald-500/20 hover:shadow-[0_0_15px_rgba(16,185,129,0.3)] transition-all duration-300 hover:-translate-y-1"
              aria-label={link.name}
            >
              {link.icon === 'github' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
              )}
              {link.icon === 'linkedin' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
              )}
              {link.icon === 'mail' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <div>
        <p class="text-xs font-semibold text-slate-300 tracking-widest uppercase mb-4">Navigasi</p>
        <ul class="space-y-2.5">
          {footerLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="group inline-flex items-center gap-2.5 text-sm text-slate-500 hover:text-emerald-400 transition-colors duration-300 font-medium"
              >
                <span class="w-1.5 h-1.5 rounded-full bg-slate-700 group-hover:bg-emerald-500 group-hover:shadow-[0_0_8px_rgba(16,185,129,0.8)] transition-all duration-300 flex-shrink-0"></span>
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="text-xs font-semibold text-slate-300 tracking-widest uppercase mb-4">Kontak</p>
        <ul class="space-y-3">
          <li>
            <a
              href={`mailto:${site.email}`}
              class="group flex items-center gap-3 text-sm text-slate-500 hover:text-emerald-400 transition-colors duration-300 font-medium"
            >
              <span class="w-8 h-8 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center flex-shrink-0 group-hover:bg-emerald-500/20 group-hover:border-emerald-500/40 group-hover:shadow-[0_0_12px_rgba(16,185,129,0.2)] transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-400"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </span>
              {site.email}
            </a>
          </li>
          <li>
            <a
              href={site.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-3 text-sm text-slate-500 hover:text-cyan-400 transition-colors duration-300 font-medium"
            >
              <span class="w-8 h-8 rounded-lg bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center flex-shrink-0 group-hover:bg-cyan-500/20 group-hover:border-cyan-500/40 group-hover:shadow-[0_0_12px_rgba(6,182,212,0.2)] transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyan-400"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
              </span>
              LinkedIn
            </a>
          </li>
          <li>
            <a
              href={site.github}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-3 text-sm text-slate-500 hover:text-slate-300 transition-colors duration-300 font-medium"
            >
              <span class="w-8 h-8 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center flex-shrink-0 group-hover:bg-white/10 group-hover:border-white/20 transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
              </span>
              GitHub
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pb-8 pt-6 border-t border-slate-800/60 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-slate-500 text-xs">
        &copy; {currentYear} Pramudya.site. All rights reserved.
      </p>
      <div class="flex items-center gap-2 flex-wrap justify-center sm:justify-end">
        <span class="text-slate-600 text-xs">Dibangun dengan</span>
        <span class="text-xs px-2.5 py-1 rounded-full bg-orange-500/10 border border-orange-500/20 text-orange-400 font-medium">Astro</span>
        <span class="text-xs px-2.5 py-1 rounded-full bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 font-medium">React</span>
        <span class="text-xs px-2.5 py-1 rounded-full bg-sky-500/10 border border-sky-500/20 text-sky-400 font-medium">Tailwind CSS</span>
      </div>
    </div>
  </div>
</footer>